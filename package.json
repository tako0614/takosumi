{
  "name": "@takosjp/takosumi",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "bin": {
    "takosumi": "cli/src/main.ts"
  },
  "workspaces": [
    "accounts/contract",
    "accounts/service",
    "cli",
    "deploy/node-postgres",
    "mobile-kit"
  ],
  "scripts": {
    "check": "bun run credential-recipes:assets && bun run provider:assets && bun run test:provider && bun run check:test-source-boundary && bun run check:generalization-boundaries && tsc --noEmit && bun run check:dashboard && bun run test:dashboard-new-flow && bun run check:worker-types && bun run check:cloudflare-worker-build",
    "check:generalization-boundaries": "bun scripts/check-generalization-boundaries.ts",
    "check:test-source-boundary": "bun scripts/check-test-source-boundary.ts",
    "check:dashboard": "(cd dashboard && bunx tsc --noEmit --pretty false -p tsconfig.json && bun run build) && bash scripts/build-app-docs.sh",
    "check:worker-types": "tsc --noEmit -p tsconfig.worker.json",
    "check:cloudflare-worker-build": "bun build --target browser --format esm --external cloudflare:workers deploy/platform/worker.ts --outfile /tmp/takosumi-platform-worker-check.mjs",
    "check:mobile-kit": "cd mobile-kit && bun run check && bun run test",
    "test": "bun test ./tests",
    "test:service": "bun test ./tests/core",
    "test:accounts": "bun test ./tests/accounts ./tests/deploy/node-postgres ./tests/deploy/accounts-cloudflare",
    "test:cli": "bun test ./tests/cli",
    "test:dashboard-new-flow": "bun test tests/dashboard/src/views/new/provider-connections-return_test.ts tests/dashboard/src/views/new/new-flow-guidance_test.ts",
    "test:provider": "cd provider && go test ./...",
    "test:scripts": "bun test ./tests/scripts",
    "provider:assets": "bun scripts/build-provider-assets.mjs",
    "credential-recipes:assets": "bun scripts/build-credential-recipe-assets.ts",
    "credential-recipes:check": "bun scripts/build-credential-recipe-assets.ts --check",
    "operator:release-activator": "bun scripts/operator-release-activator.ts",
    "opentofu:output-proof": "bun tests/proofs/opentofu-output-proof.ts",
    "opentofu:live-local-proof": "bun tests/proofs/live-opentofu-plan-apply.ts",
    "opentofu:resource-shape-provider-proof": "bun tests/proofs/resource-shape-opentofu-provider.ts",
    "opentofu:takos-shape-provider-proof": "bun tests/proofs/resource-shape-opentofu-provider.ts --profile takos-distribution",
    "opentofu:yurucommu-shape-provider-proof": "bun tests/proofs/resource-shape-opentofu-provider.ts --profile yurucommu-worker-app",
    "smoke:cloudflare": "bun scripts/smoke-cloudflare.ts",
    "smoke:platform-control-plane": "bun scripts/smoke-platform-control-plane.ts",
    "probe:accounts-rate-limit": "bun scripts/probe-accounts-rate-limit.ts",
    "release-activation:evidence": "bun scripts/validate-release-activation-evidence.ts",
    "production-hardening:evidence": "bun scripts/validate-production-hardening-evidence.ts",
    "production-hardening:gates": "bun scripts/verify-production-hardening-gates.ts",
    "ga:status": "bun ../scripts/report-takosumi-completion-status.mjs",
    "ga:live-prereqs": "bun ../scripts/check-takosumi-live-evidence-prereqs.mjs",
    "ga:billing-readiness": "bun ../scripts/check-takosumi-billing-readiness.mjs",
    "ga:billing-bootstrap": "bun ../scripts/bootstrap-takosumi-stripe-billing.mjs",
    "ga:browser-ux-evidence": "bun ../scripts/check-takosumi-browser-ux-evidence.mjs",
    "ga:browser-ux-capture": "bun ../scripts/capture-takosumi-browser-ux-evidence.mjs",
    "ga:browser-functional-e2e": "bun ../scripts/run-takosumi-browser-functional-e2e.mjs",
    "ga:browser-functional-e2e:self-test": "bun ../scripts/run-takosumi-browser-functional-e2e.mjs --self-test",
    "ga:browser-functional-e2e:check": "bun ../scripts/check-takosumi-browser-functional-e2e.mjs",
    "ga:browser-functional-e2e:check:self-test": "bun ../scripts/check-takosumi-browser-functional-e2e.mjs --self-test",
    "ga:synthetic-flow": "bun ../scripts/probe-takosumi-synthetic-flow.mjs",
    "ga:sync-readiness": "bun ../scripts/sync-takosumi-readiness-evidence.mjs",
    "ga:complete-live-evidence": "bun ../scripts/complete-takosumi-live-evidence.mjs",
    "ga:deploy-host-check": "bun ../scripts/check-cloudflare-deploy-host.mjs",
    "db:migrate": "bun core/scripts/db-migrate.ts",
    "db:migrate:dry-run": "bun core/scripts/db-migrate.ts --dry-run",
    "db:migrate:down": "bun core/scripts/db-migrate-down.ts",
    "db:migrate:rollback": "bun core/scripts/db-migrate-down.ts",
    "db:drizzle:generate:d1": "drizzle-kit generate --config drizzle.config.d1.ts",
    "db:drizzle:generate:postgres": "drizzle-kit generate --config drizzle.config.postgres.ts",
    "accounts": "bun cli/src/main.ts",
    "cli": "bun cli/src/main.ts",
    "docs:build": "cd docs && bun run build",
    "app-docs:build": "bash scripts/build-app-docs.sh",
    "app-docs:dev": "cd app-docs && ../docs/node_modules/.bin/vitepress dev --host 0.0.0.0",
    "docs:build:all": "bun run docs:build && bun run app-docs:build",
    "docs:dev": "cd docs && bun run dev",
    "website:build": "bash website/build.sh",
    "website:preview": "cd website && bun run preview",
    "website:deploy": "bash website/build.sh && bunx wrangler@latest pages deploy website/.output/public --project-name=takosumi-website --branch main"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.6",
    "age-encryption": "^0.3.0",
    "commander": "^12.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "pg": "^8.11.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "@types/bun": "^1.2.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0",
    "wrangler": "^4.101.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "ws": "8.21.0"
  }
}
