{
  "name": "@takosjp/takosumi",
  "version": "0.17.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "bin": {
    "takosumi": "packages/cli/src/main.ts"
  },
  "workspaces": [
    "packages/accounts-contract",
    "packages/accounts-service",
    "packages/cli",
    "packages/platform-services",
    "deploy/node-postgres"
  ],
  "scripts": {
    "check": "tsc --noEmit && bun run check:worker-types && bun run check:cloudflare-worker-build",
    "check:worker-types": "tsc --noEmit -p tsconfig.worker.json",
    "check:cloudflare-worker-build": "bun build --target browser --format esm --external cloudflare:workers worker/src/index.ts --outfile /tmp/takosumi-cf-worker-check.mjs && bun build --target browser --format esm worker/src/wfp_dispatch_worker.ts --outfile /tmp/takosumi-wfp-dispatch-worker-check.mjs",
    "test": "bun test ./src/ ./packages/schema/src ./packages/rootgen/src ./packages/accounts-contract/src ./packages/accounts-service ./packages/cli/src ./packages/platform-services/src ./deploy/node-postgres/src ./deploy/accounts-cloudflare/src ./worker/src ./deploy/platform ./scripts/",
    "test:service": "bun test ./src/",
    "test:accounts": "bun test ./packages/accounts-contract/src ./packages/accounts-service ./packages/cli/src ./deploy/node-postgres/src ./deploy/accounts-cloudflare/src",
    "test:scripts": "bun test ./scripts/",
    "opentofu:output-snapshot-proof": "bun scripts/prove-opentofu-output-snapshot.ts",
    "opentofu:live-local-proof": "bun scripts/prove-live-opentofu-plan-apply.ts",
    "production-hardening:evidence": "bun scripts/validate-production-hardening-evidence.ts",
    "production-hardening:gates": "bun scripts/verify-production-hardening-gates.ts",
    "db:migrate": "bun src/service/scripts/db-migrate.ts",
    "db:migrate:dry-run": "bun src/service/scripts/db-migrate.ts --dry-run",
    "db:migrate:down": "bun src/service/scripts/db-migrate-down.ts",
    "db:migrate:rollback": "bun src/service/scripts/db-migrate-down.ts",
    "db:drizzle:generate:d1": "drizzle-kit generate --config drizzle.config.d1.ts",
    "db:drizzle:generate:postgres": "drizzle-kit generate --config drizzle.config.postgres.ts",
    "accounts": "bun packages/cli/src/main.ts",
    "cli": "bun packages/cli/src/main.ts",
    "docs:build": "cd docs && bun run build",
    "docs:dev": "cd docs && bun run dev",
    "website:build": "bash website/build.sh",
    "website:preview": "cd website && bun run preview",
    "website:deploy": "bash website/build.sh && bunx wrangler pages deploy website/.output/public --project-name=takosumi-website"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.6",
    "commander": "^12.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "pg": "^8.11.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0",
    "wrangler": "^4.61.0"
  }
}
