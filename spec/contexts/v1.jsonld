{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://takosumi.com/vocab/v1#",
    "takosumi": "https://takosumi.com/vocab/v1#",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "ComponentKind": "takosumi:ComponentKind",
    "AppSpec": "takosumi:AppSpec",
    "Component": "takosumi:Component",
    "Installation": "takosumi:Installation",
    "Deployment": "takosumi:Deployment",
    "CapabilityTerm": "takosumi:CapabilityTerm",
    "OutputField": "takosumi:OutputField",
    "SpecField": "takosumi:SpecField",
    "PublishDeclaration": "takosumi:PublishDeclaration",
    "ListenDeclaration": "takosumi:ListenDeclaration",

    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "version": {
      "@id": "takosumi:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "spec": {
      "@id": "takosumi:spec",
      "@type": "@json"
    },
    "outputs": {
      "@id": "takosumi:outputs",
      "@container": "@set"
    },
    "capabilityTerms": {
      "@id": "takosumi:capabilityTerms",
      "@container": "@set"
    },
    "referenceAliases": {
      "@id": "takosumi:referenceAliases",
      "@container": "@set"
    },
    "outputSlots": {
      "@id": "takosumi:outputSlots",
      "@type": "@json"
    },
    "listens": {
      "@id": "takosumi:listens",
      "@type": "@json"
    },
    "servicePath": {
      "@id": "takosumi:servicePath",
      "@type": "xsd:string"
    },
    "contract": {
      "@id": "takosumi:contract",
      "@type": "xsd:string"
    },
    "exampleMaterialMapping": {
      "@id": "takosumi:exampleMaterialMapping",
      "@type": "@json"
    },
    "accepts": {
      "@id": "takosumi:accepts",
      "@container": "@set"
    },
    "projectionFamilies": {
      "@id": "takosumi:projectionFamilies",
      "@container": "@set"
    },
    "minimumAccess": {
      "@id": "takosumi:minimumAccess",
      "@type": "xsd:string"
    },
    "safeDefaultAccess": {
      "@id": "takosumi:safeDefaultAccess",
      "@type": "xsd:string"
    },
    "accessModes": {
      "@id": "takosumi:accessModes",
      "@container": "@set"
    },
    "sensitivity": {
      "@id": "takosumi:sensitivity",
      "@type": "xsd:string"
    },
    "requiredWhenReferencedBy": {
      "@id": "takosumi:requiredWhenReferencedBy",
      "@type": "xsd:string"
    },
    "type": {
      "@id": "takosumi:fieldType",
      "@type": "xsd:string"
    },
    "required": {
      "@id": "takosumi:required"
    },
    "meaning": {
      "@id": "takosumi:meaning",
      "@type": "xsd:string"
    },
    "items": {
      "@id": "takosumi:items",
      "@type": "@json"
    },
    "enum": {
      "@id": "takosumi:enum",
      "@container": "@set"
    },
    "default": {
      "@id": "takosumi:default"
    }
  }
}
