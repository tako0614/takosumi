{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://takosumi.com/vocab/v1#",
    "takosumi": "https://takosumi.com/vocab/v1#",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "ComponentKind": "takosumi:ComponentKind",
    "AppSpec": "takosumi:AppSpec",
    "Component": "takosumi:Component",
    "Installation": "takosumi:Installation",
    "Deployment": "takosumi:Deployment",
    "CapabilityTerm": "takosumi:CapabilityTerm",
    "OutputField": "takosumi:OutputField",
    "SpecField": "takosumi:SpecField",
    "PublishDeclaration": "takosumi:PublishDeclaration",
    "ListenDeclaration": "takosumi:ListenDeclaration",

    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "version": {
      "@id": "takosumi:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "spec": {
      "@id": "takosumi:spec",
      "@type": "@json"
    },
    "outputs": {
      "@id": "takosumi:outputs",
      "@container": "@set"
    },
    "capabilityTerms": {
      "@id": "takosumi:capabilityTerms",
      "@container": "@set"
    },
    "referenceAliases": {
      "@id": "takosumi:referenceAliases",
      "@container": "@set"
    },
    "publications": {
      "@id": "takosumi:publications",
      "@type": "@json"
    },
    "acceptedProjectionFamilies": {
      "@id": "takosumi:acceptedProjectionFamilies",
      "@container": "@set"
    },
    "publicationPath": {
      "@id": "takosumi:publicationPath",
      "@type": "xsd:string"
    },
    "contract": {
      "@id": "takosumi:contract",
      "@type": "xsd:string"
    },
    "material": {
      "@id": "takosumi:material",
      "@type": "@json"
    },
    "type": {
      "@id": "takosumi:fieldType",
      "@type": "xsd:string"
    },
    "required": {
      "@id": "takosumi:required"
    },
    "meaning": {
      "@id": "takosumi:meaning",
      "@type": "xsd:string"
    },
    "enum": {
      "@id": "takosumi:enum",
      "@container": "@set"
    },
    "default": {
      "@id": "takosumi:default"
    }
  }
}
