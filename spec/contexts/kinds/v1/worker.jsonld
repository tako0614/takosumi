{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/worker",
  "@type": "ComponentKind",
  "name": "worker",
  "version": "v1",
  "description": "Serverless JS function backed by an uploaded `js-bundle` artifact.",
  "spec": [
    {
      "name": "artifact",
      "type": "object",
      "required": true,
      "meaning": "Artifact descriptor. `artifact.kind` must be `js-bundle`; `artifact.hash` is required (no external `uri`)."
    },
    {
      "name": "compatibilityDate",
      "type": "string",
      "required": true,
      "meaning": "Cloudflare Workers compatibility date (e.g. `2025-01-01`)."
    },
    {
      "name": "compatibilityFlags",
      "type": "string[]",
      "required": false,
      "meaning": "Optional compatibility flags (e.g. `nodejs_compat`)."
    },
    {
      "name": "env",
      "type": "Record<string,string>",
      "required": false,
      "meaning": "Optional env vars / bindings."
    },
    {
      "name": "routes",
      "type": "string[]",
      "required": false,
      "meaning": "Route patterns the worker handles (e.g. `/`, `/api/*`)."
    }
  ],
  "outputs": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "meaning": "Allocated public URL (scheme-bearing)."
    },
    {
      "name": "scriptName",
      "type": "string",
      "required": true,
      "meaning": "Provider-scope worker identifier."
    },
    {
      "name": "version",
      "type": "string",
      "required": false,
      "meaning": "Current deployed bundle version."
    }
  ],
  "capabilities": [
    "scale-to-zero",
    "websocket",
    "long-request",
    "geo-routing",
    "crons"
  ]
}
