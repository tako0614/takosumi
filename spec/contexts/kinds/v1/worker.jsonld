{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/worker",
  "@type": "ComponentKind",
  "name": "worker",
  "version": "v1",
  "description": "Serverless JS function backed by an uploaded `js-bundle` artifact.",
  "x-ts": {
    "fileBasename": "worker",
    "prefix": "Worker",
    "shapeId": "worker"
  },
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["artifact", "compatibilityDate"],
    "additionalProperties": false,
    "properties": {
      "artifact": {
        "type": "object",
        "description": "Artifact descriptor. `artifact.kind` must be `js-bundle`; `artifact.hash` is required (no external `uri`).",
        "required": ["kind", "hash"],
        "x-ts-type": {
          "import": "takosumi-contract",
          "name": "Artifact"
        },
        "properties": {
          "kind": { "const": "js-bundle" },
          "hash": { "type": "string", "minLength": 1 }
        }
      },
      "compatibilityDate": {
        "type": "string",
        "minLength": 1,
        "description": "Cloudflare Workers compatibility date (e.g. `2025-01-01`)."
      },
      "compatibilityFlags": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "description": "Optional compatibility flags (e.g. `nodejs_compat`)."
      },
      "env": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Optional env vars / bindings."
      },
      "routes": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "description": "Route patterns the worker handles (e.g. `/`, `/api/*`)."
      }
    }
  },
  "outputs": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "meaning": "Allocated public URL (scheme-bearing)."
    },
    {
      "name": "scriptName",
      "type": "string",
      "required": true,
      "meaning": "Provider-scope worker identifier."
    },
    {
      "name": "version",
      "type": "string",
      "required": false,
      "meaning": "Current deployed bundle version."
    }
  ],
  "capabilities": [
    "scale-to-zero",
    "websocket",
    "long-request",
    "geo-routing",
    "crons"
  ]
}
