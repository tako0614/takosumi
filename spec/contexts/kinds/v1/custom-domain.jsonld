{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/custom-domain",
  "@type": "ComponentKind",
  "name": "custom-domain",
  "version": "v1",
  "description": "DNS + TLS-terminated public domain pointing at a target URL.",
  "x-ts": {
    "fileBasename": "custom-domain",
    "prefix": "CustomDomain",
    "shapeId": "custom-domain"
  },
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name", "target"],
    "additionalProperties": false,
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Fully-qualified domain name (e.g. `notes.example.com`)."
      },
      "target": {
        "type": "string",
        "minLength": 1,
        "description": "Component name whose `url` output this domain points at."
      },
      "certificate": {
        "type": "object",
        "required": ["kind"],
        "description": "TLS certificate provisioning policy. `secretRef` is required when `kind: provided`.",
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["auto", "managed", "provided"]
          },
          "secretRef": { "type": "string", "minLength": 1 }
        }
      },
      "redirects": {
        "type": "array",
        "description": "HTTP redirect rules served by the domain edge.",
        "items": {
          "type": "object",
          "x-ts-name": "Redirect",
          "required": ["from", "to"],
          "properties": {
            "from": { "type": "string", "minLength": 1 },
            "to": { "type": "string", "minLength": 1 },
            "code": { "type": "integer", "enum": [301, 302, 307, 308] }
          }
        }
      }
    }
  },
  "outputs": [
    {
      "name": "fqdn",
      "type": "string",
      "required": true,
      "meaning": "Resolved fully-qualified domain name."
    },
    {
      "name": "certificateArn",
      "type": "string",
      "required": false,
      "meaning": "Provider-scope TLS certificate identifier."
    },
    {
      "name": "nameservers",
      "type": "string[]",
      "required": false,
      "meaning": "DNS nameserver list (when delegated)."
    }
  ],
  "capabilities": [
    "wildcard",
    "auto-tls",
    "sni",
    "http3",
    "alpn-acme",
    "redirects"
  ]
}
