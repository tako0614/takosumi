      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 7
      },
      "id": 4,
      "targets": [
        {
          "expr": "1 - (sum(increase(takosumi_cloud_spend_cents_total{space_id=\"\",provider=~\"$provider\"}[24h])) / clamp_min(sum(increase(takosumi_cloud_spend_cents_total{provider=~\"$provider\"}[24h])), 1))",
