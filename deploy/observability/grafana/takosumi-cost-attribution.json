      "id": 3,
      "targets": [
        {
          "expr": "1 - (sum(increase(takosumi_cloud_spend_cents_total{space_id=~\"$space_id\",provider=~\"$provider\"}[30d])) / 100) / clamp_min(sum(increase(takosumi_usage_credits_total{space_id=~\"$space_id\"}[30d])), 1)",
          "legendFormat": "gross margin",
          "refId": "A"
        }
