{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(takosumi_deploy_operation_count{environment=~\"$environment\",runner_profile_id=~\"$runner_profile_id\",workspace_id=~\"$workspace_id\",capsule_id=~\"$capsule_id\",operation_kind=\"apply\",status=\"succeeded\"}[5m])) / clamp_min(sum(rate(takosumi_deploy_operation_count{environment=~\"$environment\",runner_profile_id=~\"$runner_profile_id\",workspace_id=~\"$workspace_id\",capsule_id=~\"$capsule_id\",operation_kind=\"apply\"}[5m])), 1)",
          "legendFormat": "apply success rate",
          "refId": "A"
        }
      ],
      "title": "Apply Success Rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(takosumi_apply_duration_seconds_bucket{environment=~\"$environment\",runner_profile_id=~\"$runner_profile_id\",workspace_id=~\"$workspace_id\",capsule_id=~\"$capsule_id\",operation_kind=\"apply\"}[5m])) by (le))",
          "legendFormat": "p95 apply latency",
          "refId": "A"
        }
      ],
      "title": "Apply Latency P95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "max(takosumi_runner_queue_age_seconds{environment=~\"$environment\",runner_profile_id=~\"$runner_profile_id\"})",
          "legendFormat": "{{runner_profile_id}} queue age",
          "refId": "A"
        }
      ],
      "title": "Runner Queue Age",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 7
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (runner_profile_id, status) (rate(takosumi_deploy_operation_count{environment=~\"$environment\",runner_profile_id=~\"$runner_profile_id\",operation_kind=~\"plan|apply|destroy_apply\"}[5m]))",
          "legendFormat": "{{runner_profile_id}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Run Throughput By Runner Profile",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 7
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (runner_profile_id) (takosumi_runner_active_runs{environment=~\"$environment\",runner_profile_id=~\"$runner_profile_id\"})",
          "legendFormat": "{{runner_profile_id}} active",
          "refId": "A"
        }
      ],
      "title": "Active Runner Runs",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 7
      },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(takosumi_runner_container_startup_seconds_bucket{environment=~\"$environment\",runner_profile_id=~\"$runner_profile_id\"}[5m])) by (le, runner_profile_id))",
          "legendFormat": "{{runner_profile_id}} p95 startup",
          "refId": "A"
        }
      ],
      "title": "Runner Container Startup P95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 15
      },
      "id": 7,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(takosumi_api_request_duration_seconds_bucket{environment=~\"$environment\",route=~\"/api/.*\"}[5m])) by (le, route))",
          "legendFormat": "{{route}} p95",
          "refId": "A"
        }
      ],
      "title": "API Latency P95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 15
      },
      "id": 8,
      "targets": [
        {
          "expr": "sum by (workspace_id, capsule_id, operation_kind, status) (increase(takosumi_deploy_operation_count{environment=~\"$environment\",workspace_id=~\"$workspace_id\",capsule_id=~\"$capsule_id\"}[1h]))",
          "legendFormat": "{{workspace_id}} / {{capsule_id}} / {{operation_kind}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Per Capsule Run Outcomes",
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 15
      },
      "id": 9,
      "targets": [
        {
          "expr": "sum by (status) (rate(takosumi_oidc_request_count{environment=~\"$environment\"}[5m]))",
          "legendFormat": "oidc {{status}}",
          "refId": "A"
        }
      ],
      "title": "OIDC Request Status",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["takosumi", "deploy", "runtime"],
