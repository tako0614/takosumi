# Takosumi Accounts — Bun + Postgres reference distribution.
#
# Replace every "replace-me..." / placeholder before going to production.
# Do not commit a populated copy of this file: secrets live in your
# operator secret store (Docker secrets, Kubernetes Secrets, Vault, etc.).
# Group order matches the parser layout in src/handler.ts so operators
# can audit one env block at a time.

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=replace-me-with-a-strong-passphrase
# Override the connection string only when running the accounts process
# outside docker-compose. Inside compose, the URL is built from
# POSTGRES_PASSWORD and the `postgres` service alias.
# TAKOSUMI_ACCOUNTS_DATABASE_URL=postgres://takosumi:replace-me-with-a-strong-passphrase@postgres:5432/takosumi_accounts
# Postgres pool tuning consumed by src/server.ts. Defaults shown.
# TAKOSUMI_ACCOUNTS_PG_POOL_MAX=20
# TAKOSUMI_ACCOUNTS_PG_IDLE_TIMEOUT_MS=30000
# TAKOSUMI_ACCOUNTS_PG_CONNECT_TIMEOUT_MS=5000
# TAKOSUMI_ACCOUNTS_PG_STATEMENT_TIMEOUT_MS=30000
# disable | require | verify-ca | verify-full
# TAKOSUMI_ACCOUNTS_PG_SSL_MODE=disable
# PEM-encoded CA bundle (verify-ca / verify-full)
# TAKOSUMI_ACCOUNTS_PG_SSL_ROOT_CERT=

# ---------------------------------------------------------------------------
# Listener / OIDC issuer
# ---------------------------------------------------------------------------
# Public issuer URL advertised in /.well-known/openid-configuration.
TAKOSUMI_ACCOUNTS_ISSUER=https://accounts.example.com
# Public hostname (eTLD+1 user-facing) used by Caddy as the site label
# in Caddyfile.example. This is the externally-resolvable domain and
# must match the certificate Caddy provisions over ACME / Let's Encrypt.
TAKOSUMI_ACCOUNTS_PUBLIC_HOSTNAME=accounts.example.com
# Bind interface for the in-process HTTP server. Caddy already terminates TLS,
# so the accounts container only needs to listen on the docker-compose network.
# Default `0.0.0.0` listens on all interfaces inside the container.
TAKOSUMI_ACCOUNTS_BIND_HOST=0.0.0.0
# Port the accounts process listens on inside the container.
# TAKOSUMI_ACCOUNTS_PORT=8787
# Long-lived ES256 JWK used to sign OIDC ID tokens. Format: a serialized
# JSON Web Key with the private "d" coordinate. REQUIRED for an https issuer:
# the service now FAILS CLOSED at startup (refuses to boot) when
# TAKOSUMI_ACCOUNTS_ISSUER is https and no stable JWK is set, because the
# ephemeral fallback rotates the signing key on every restart / replica and
# breaks id_token verification. Only localhost / plain-http dev issuers may
# run in the ephemeral fallback. Provide a real JWK here for production.
TAKOSUMI_ACCOUNTS_ES256_PRIVATE_JWK={"kty":"EC","crv":"P-256","d":"replace-with-private-d","x":"replace-with-public-x","y":"replace-with-public-y"}
# Optional explicit key id; defaults to the JWK's `kid` or a stable
# fallback string.
# TAKOSUMI_ACCOUNTS_ES256_KEY_ID=
# Pre-rotated secret used to derive pairwise OIDC subject identifiers.
# Required when TAKOSUMI_ACCOUNTS_ES256_PRIVATE_JWK is set.
TAKOSUMI_ACCOUNTS_OIDC_PAIRWISE_SUBJECT_SECRET=replace-me-with-a-64-char-random-string
# Pre-rotated secret used to derive pairwise launch-token subjects.
# Required when TAKOSUMI_ACCOUNTS_ES256_PRIVATE_JWK is set.
TAKOSUMI_ACCOUNTS_LAUNCH_TOKEN_PAIRWISE_SECRET=replace-me-with-another-64-char-random-string
# Optional fixed subject used by the OIDC authorization code flow in
# operator-controlled single-tenant deployments.
# TAKOSUMI_ACCOUNTS_SUBJECT=tsub_operator_seed

# ---------------------------------------------------------------------------
# Default OIDC client (downstream Takos / dashboards)
# ---------------------------------------------------------------------------
TAKOSUMI_ACCOUNTS_CLIENT_ID=takos-app
TAKOSUMI_ACCOUNTS_REDIRECT_URIS=https://app.example.com/oauth/callback
# Optional confidential client secret. Leave blank for PKCE-only public clients.
TAKOSUMI_ACCOUNTS_CLIENT_SECRET=
# Optional JSON array if you need to register multiple OIDC clients.
# TAKOSUMI_ACCOUNTS_CLIENTS=[{"clientId":"takos-app","redirectUris":["https://app.example.com/oauth/callback"]}]

# ---------------------------------------------------------------------------
# Passkeys (WebAuthn)
# ---------------------------------------------------------------------------
# WebAuthn relying-party identifier (eTLD+1 of the dashboard origin).
TAKOSUMI_ACCOUNTS_PASSKEY_RP_ID=accounts.example.com
# Human readable name shown by the platform authenticator UI.
TAKOSUMI_ACCOUNTS_PASSKEY_RP_NAME=Takosumi Accounts
# Browser origin used to validate WebAuthn assertions.
TAKOSUMI_ACCOUNTS_PASSKEY_RP_ORIGIN=https://accounts.example.com
# Session TTL for passkey login transactions. Either form is accepted.
# TAKOSUMI_ACCOUNTS_PASSKEY_TTL_SECONDS=300
# TAKOSUMI_ACCOUNTS_PASSKEY_SESSION_TTL_MS=300000

# ---------------------------------------------------------------------------
# Upstream identity providers (Google / GitHub / Apple / Custom OIDC)
# ---------------------------------------------------------------------------
# Shared subject-hashing secret. Required when any upstream provider is configured.
TAKOSUMI_ACCOUNTS_SUBJECT_SECRET=replace-me-with-a-random-secret
# Optional session TTL applied to upstream-driven sessions.
# TAKOSUMI_ACCOUNTS_UPSTREAM_SESSION_TTL_MS=3600000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_CLIENT_ID=
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_CLIENT_SECRET=
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_REDIRECT_URI=https://accounts.example.com/v1/auth/upstream/callback
# Space- or comma-separated scope list.
# TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_SCOPES=openid email profile
# Optional endpoint overrides (useful for proxies / self-hosted mirrors).
# TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_ISSUER=
# TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_AUTHORIZATION_ENDPOINT=
# TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_TOKEN_ENDPOINT=
# TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_USERINFO_ENDPOINT=

# GitHub OAuth (https://github.com/settings/developers)
TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_CLIENT_ID=
TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_CLIENT_SECRET=
TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_REDIRECT_URI=https://accounts.example.com/v1/auth/upstream/callback
# TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_SCOPES=read:user user:email
# TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_ISSUER=
# TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_AUTHORIZATION_ENDPOINT=
# TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_TOKEN_ENDPOINT=
# TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_USERINFO_ENDPOINT=

# Sign-in with Apple (https://developer.apple.com/account/resources/identifiers/list/serviceId)
# Client secret here is an Apple client-secret JWT signed with your private key.
TAKOSUMI_ACCOUNTS_UPSTREAM_APPLE_CLIENT_ID=
TAKOSUMI_ACCOUNTS_UPSTREAM_APPLE_CLIENT_SECRET=
TAKOSUMI_ACCOUNTS_UPSTREAM_APPLE_REDIRECT_URI=https://accounts.example.com/v1/auth/upstream/callback
# TAKOSUMI_ACCOUNTS_UPSTREAM_APPLE_SCOPES=name email
# TAKOSUMI_ACCOUNTS_UPSTREAM_APPLE_ISSUER=https://appleid.apple.com
# TAKOSUMI_ACCOUNTS_UPSTREAM_APPLE_AUTHORIZATION_ENDPOINT=
# TAKOSUMI_ACCOUNTS_UPSTREAM_APPLE_TOKEN_ENDPOINT=
# TAKOSUMI_ACCOUNTS_UPSTREAM_APPLE_USERINFO_ENDPOINT=
# TAKOSUMI_ACCOUNTS_UPSTREAM_APPLE_SUBJECT_CLAIM=sub

# Custom OIDC IdP (Keycloak, Authentik, Auth0, Entra ID, etc.).
# TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_PROVIDER_ID=
# TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_ISSUER=
# TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_AUTHORIZATION_ENDPOINT=
# TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_TOKEN_ENDPOINT=
# TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_USERINFO_ENDPOINT=
# TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_SUBJECT_CLAIM=sub
# TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_CLIENT_ID=
# TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_CLIENT_SECRET=
# TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_REDIRECT_URI=
# TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_SCOPES=openid email profile

# ---------------------------------------------------------------------------
# Stripe billing
# ---------------------------------------------------------------------------
# Stripe secret API key (https://dashboard.stripe.com/apikeys).
TAKOSUMI_ACCOUNTS_STRIPE_API_KEY=
# Stripe webhook signing secret (https://dashboard.stripe.com/webhooks).
TAKOSUMI_ACCOUNTS_STRIPE_WEBHOOK_SECRET=
# Stripe publishable key surfaced to dashboards / SDKs.
TAKOSUMI_ACCOUNTS_STRIPE_PUBLIC_KEY=
# Optional Stripe API base override (e.g. when proxied through a sandbox).
# TAKOSUMI_ACCOUNTS_STRIPE_API_BASE=https://api.stripe.com
# Webhook tolerance window in seconds (default 300).
# TAKOSUMI_ACCOUNTS_STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# ---------------------------------------------------------------------------
# Installer / dashboard / workload platform service resolver
# ---------------------------------------------------------------------------
# Bearer token used by takos-app (and other workload consumers) to call
# the in-process resolver for `identity.primary.oidc` etc.
# TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICE_RESOLVER_TOKEN=
# TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICES_INTERNAL_URL=
# TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICES_ALLOW_DIRECT_DEPLOY_CONTROL=false
# TAKOSUMI_ACCOUNTS_BILLING_PORTAL_URL=https://billing.example.com/portal

# ---------------------------------------------------------------------------
# Installation export downloads (filesystem + signed static download URLs)
# ---------------------------------------------------------------------------
# Exports are OPT-IN: leave all four vars commented out (the default) to run
# without the export worker. Uncomment the block to enable it. When ANY of
# the four vars is set, ALL three required vars (secret / output dir / base
# URL) MUST be set together or the service refuses to start.
#
# HMAC secret used to SIGN and verify the time-limited export download URLs
# this profile emits (mirrors the Cloudflare profile's
# TAKOSUMI_ACCOUNTS_EXPORT_DOWNLOAD_SECRET). Set a high-entropy random value.
# TAKOSUMI_ACCOUNTS_EXPORT_DOWNLOAD_SECRET=
# Filesystem directory on the accounts container where archive files are
# written. The shipped docker-compose.yml mounts the `exports-data` volume
# here so it stays writable under `read_only: true`; if you change this path
# also change that mount (or bind-mount a writable host directory).
# TAKOSUMI_ACCOUNTS_EXPORT_OUTPUT_DIR=/var/lib/takosumi-accounts/exports
# Public URL prefix that, combined with the archive filename and the signed
# query parameters, yields the download URL embedded in the operation
# response. Must point at the static server serving EXPORT_OUTPUT_DIR.
# TAKOSUMI_ACCOUNTS_EXPORT_DOWNLOAD_BASE_URL=https://accounts.example.com/exports/
# Optional TTL for signed export download URLs, in milliseconds (default 24h).
# TAKOSUMI_ACCOUNTS_EXPORT_DOWNLOAD_TTL_MS=86400000

# ---------------------------------------------------------------------------
# Managed offering access gate
# ---------------------------------------------------------------------------
# closed | open. `open` requires the readiness digest below.
TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_ACCESS=closed
# sha256 digest of the launch readiness evidence bundle.
TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_READINESS_DIGEST=
# Optional pointers to evidence / approval records / public summary.
# TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_EVIDENCE_REF=
# TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_APPROVAL_REF=
# TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_PUBLIC_SUMMARY=
