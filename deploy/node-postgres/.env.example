# Takosumi Accounts — Bun + Postgres reference distribution.
#
# Replace every "replace-me..." / placeholder before going to production.
# Do not commit a populated copy of this file: secrets live in your
# operator secret store (Docker secrets, Kubernetes Secrets, Vault, etc.).
# Group order matches the parser layout in src/handler.ts so operators
# can audit one env block at a time.

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=replace-me-with-a-strong-passphrase
# Override the connection string only when running the accounts process
# outside docker-compose. Inside compose, the URL is built from
# POSTGRES_PASSWORD and the `postgres` service alias.
# TAKOSUMI_ACCOUNTS_DATABASE_URL=postgres://takosumi:replace-me-with-a-strong-passphrase@postgres:5432/takosumi_accounts
# Postgres pool tuning consumed by src/server.ts. Defaults shown.
# TAKOSUMI_ACCOUNTS_PG_POOL_MAX=20
# TAKOSUMI_ACCOUNTS_PG_IDLE_TIMEOUT_MS=30000
# TAKOSUMI_ACCOUNTS_PG_CONNECT_TIMEOUT_MS=5000
# TAKOSUMI_ACCOUNTS_PG_STATEMENT_TIMEOUT_MS=30000
# disable | require | verify-ca | verify-full
# TAKOSUMI_ACCOUNTS_PG_SSL_MODE=disable
# PEM-encoded CA bundle (verify-ca / verify-full)
# TAKOSUMI_ACCOUNTS_PG_SSL_ROOT_CERT=

# ---------------------------------------------------------------------------
# Listener / OIDC issuer
# ---------------------------------------------------------------------------
# Public issuer URL advertised in /.well-known/openid-configuration.
TAKOSUMI_ACCOUNTS_ISSUER=https://accounts.example.com
# Public hostname (eTLD+1 user-facing) used by Caddy as the site label
# in Caddyfile.example. This is the externally-resolvable domain and
# must match the certificate Caddy provisions over ACME / Let's Encrypt.
TAKOSUMI_ACCOUNTS_PUBLIC_HOSTNAME=accounts.example.com
# Bind interface for the in-process HTTP server. Caddy already terminates TLS,
# so the accounts container only needs to listen on the docker-compose network.
# Default `0.0.0.0` listens on all interfaces inside the container.
TAKOSUMI_ACCOUNTS_BIND_HOST=0.0.0.0
# Port the accounts process listens on inside the container.
# TAKOSUMI_ACCOUNTS_PORT=8787
# Long-lived ES256 JWK used to sign OIDC ID tokens. Format: a serialized
# JSON Web Key with the private "d" coordinate. REQUIRED for an https issuer:
# the service now FAILS CLOSED at startup (refuses to boot) when
# TAKOSUMI_ACCOUNTS_ISSUER is https and no stable JWK is set, because the
# ephemeral fallback rotates the signing key on every restart / replica and
# breaks id_token verification. Only localhost / plain-http dev issuers may
# run in the ephemeral fallback. Provide a real JWK here for production.
TAKOSUMI_ACCOUNTS_ES256_PRIVATE_JWK={"kty":"EC","crv":"P-256","d":"replace-with-private-d","x":"replace-with-public-x","y":"replace-with-public-y"}
# Optional explicit key id; defaults to the JWK's `kid` or a stable
# fallback string.
# TAKOSUMI_ACCOUNTS_ES256_KEY_ID=
# Optional public-only JWKS for the previous signing key during rotation
# overlap. Never include private "d" values here.
# TAKOSUMI_ACCOUNTS_ES256_PREVIOUS_PUBLIC_JWKS={"keys":[{"kty":"EC","crv":"P-256","kid":"previous-key","x":"previous-public-x","y":"previous-public-y"}]}
# Pre-rotated secret used to derive pairwise OIDC subject identifiers.
# Required when TAKOSUMI_ACCOUNTS_ES256_PRIVATE_JWK is set.
TAKOSUMI_ACCOUNTS_OIDC_PAIRWISE_SUBJECT_SECRET=replace-me-with-a-64-char-random-string
# Optional fixed subject used by the OIDC authorization code flow in
# operator-controlled single-tenant deployments.
# TAKOSUMI_ACCOUNTS_SUBJECT=tsub_operator_seed

# ---------------------------------------------------------------------------
# Default OIDC client (downstream Takos / dashboards)
# ---------------------------------------------------------------------------
TAKOSUMI_ACCOUNTS_CLIENT_ID=takos-app
TAKOSUMI_ACCOUNTS_REDIRECT_URIS=https://app.example.com/oauth/callback
# Optional confidential client secret. Leave blank for PKCE-only public clients.
TAKOSUMI_ACCOUNTS_CLIENT_SECRET=
TAKOSUMI_ACCOUNTS_CLIENT_AUTH_METHOD=none
# Optional exact scope allowlist for the singular client.
TAKOSUMI_ACCOUNTS_ALLOWED_SCOPES=openid,profile,offline_access
# Optional JSON array if you need to register multiple OIDC clients.
# A Takos native client is public (`none`), uses the exact custom-scheme
# redirect below, and has an explicit least-privilege scope allowlist. Give
# every Takos host a distinct client id and advertise that id from the host's
# OIDC_MOBILE_CLIENT_ID binding.
# TAKOSUMI_ACCOUNTS_CLIENTS=[{"clientId":"takos-web-example","redirectUris":["https://takos.example.com/auth/oidc/callback"],"tokenEndpointAuthMethod":"client_secret_post"},{"clientId":"takos-mobile-example","redirectUris":["takos://oauth/callback"],"tokenEndpointAuthMethod":"none","allowedScopes":["openid","profile","offline_access","spaces:read","spaces:write","threads:read","threads:write","runs:read","runs:write","agents:execute","memories:read","memories:write"]},{"clientId":"takosumi-mobile-example","redirectUris":["takosumi://oauth/callback"],"tokenEndpointAuthMethod":"none","allowedScopes":["openid","profile","offline_access","capsules:read","capsules:write"]}]
# TAKOSUMI_MOBILE_OIDC_CLIENT_ID=takosumi-mobile-example

# ---------------------------------------------------------------------------
# Passkeys (WebAuthn)
# ---------------------------------------------------------------------------
# WebAuthn relying-party identifier (eTLD+1 of the dashboard origin).
TAKOSUMI_ACCOUNTS_PASSKEY_RP_ID=accounts.example.com
# Human readable name shown by the platform authenticator UI.
TAKOSUMI_ACCOUNTS_PASSKEY_RP_NAME=Takosumi Accounts
# Browser origin used to validate WebAuthn assertions.
TAKOSUMI_ACCOUNTS_PASSKEY_RP_ORIGIN=https://accounts.example.com
# Session TTL for passkey login transactions. Either form is accepted.
# TAKOSUMI_ACCOUNTS_PASSKEY_TTL_SECONDS=300
# TAKOSUMI_ACCOUNTS_PASSKEY_SESSION_TTL_MS=300000

# ---------------------------------------------------------------------------
# Upstream identity providers (zero or more explicit OAuth/OIDC descriptors)
# ---------------------------------------------------------------------------
# Shared subject-hashing secret. Required when any upstream provider is configured.
# TAKOSUMI_ACCOUNTS_SUBJECT_SECRET=replace-me-with-a-random-secret
# Optional session TTL applied to upstream-driven sessions.
# TAKOSUMI_ACCOUNTS_UPSTREAM_SESSION_TTL_MS=3600000

# Descriptor JSON contains endpoints and secret binding names, never secret
# values. Add any number of providers; providerId does not select behavior.
# TAKOSUMI_ACCOUNTS_UPSTREAM_PROVIDERS=[{"providerId":"company-sso","label":"Company SSO","issuer":"https://id.example.com","authorizationEndpoint":"https://id.example.com/oauth/authorize","tokenEndpoint":"https://id.example.com/oauth/token","userInfoEndpoint":"https://id.example.com/oauth/userinfo","clientId":"accounts-client","clientSecretEnv":"COMPANY_SSO_CLIENT_SECRET","redirectUri":"https://accounts.example.com/sign-in/callback","scopes":["openid","profile","email"]}]
# COMPANY_SSO_CLIENT_SECRET=replace-me

# ---------------------------------------------------------------------------
# Billing (showback only)
# ---------------------------------------------------------------------------
# OSS / Takosumi for-Operators billing is a non-blocking showback ledger only.
# Stripe / official billing / enforced payment gating is a Takosumi Cloud-only
# closed feature (served by the takosumi-cloud `billing-enforce` module), so no
# Stripe configuration is read here.

# ---------------------------------------------------------------------------
# Installer / dashboard / workload platform service resolver
# ---------------------------------------------------------------------------
# Bearer token used by takos-app (and other workload consumers) to call
# the in-process resolver for `identity.primary.oidc` etc.
# TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICE_RESOLVER_TOKEN=
# TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICES_INTERNAL_URL=
# TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICES_ALLOW_DIRECT_DEPLOY_CONTROL=false
# TAKOSUMI_ACCOUNTS_BILLING_PORTAL_URL=https://billing.example.com/portal

# Operator token required for POST /v1/privacy/requests/:requestId/complete.
# Customers can create/read their own privacy requests with their account
# session, but completion is operator evidence and must use this token.
# TAKOSUMI_ACCOUNTS_PRIVACY_OPERATIONS_TOKEN=
