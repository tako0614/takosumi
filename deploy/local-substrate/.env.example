# Copy to .env (gitignored) and override locally.

# MinIO root credentials (shared by kernel + runtime-agent)
MINIO_ROOT_USER=takos
MINIO_ROOT_PASSWORD=takos-minio-pw

# Kernel ↔ runtime-agent shared secret
TAKOSUMI_AGENT_TOKEN=local-substrate-agent-token

# Kernel deploy bearer token (CLI / smoke / route-registrar が POST /v1/deployments する時に使う)
TAKOSUMI_DEPLOY_TOKEN=local-substrate-deploy-token

# kernel ↔ accounts 共通の internal service secret
TAKOS_INTERNAL_SERVICE_SECRET=local-dev-secret

# Phase 2 — real cloud credentials. Set only if you want that cloud's
# connector to register. Without credentials the factory skips the
# connector and any manifest requesting it fails with "provider not configured".
#
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# GCP_PROJECT=
# GCP_SERVICE_ACCOUNT_KEY_JSON=
#
# AZURE_SUBSCRIPTION_ID=
# AZURE_BEARER_TOKEN=
#
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
#
# KUBE_API_SERVER_URL=
# KUBE_BEARER_TOKEN=
