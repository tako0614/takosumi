# Copy to .env (gitignored) and override locally.

# MinIO root credentials (shared by kernel + runtime-agent)
MINIO_ROOT_USER=takos
MINIO_ROOT_PASSWORD=takos-minio-pw

# Takosumi service ↔ runtime-agent shared token.
TAKOSUMI_AGENT_TOKEN=local-substrate-agent-token

# Deploy-control bearer tokens used by local CLI / smoke flows.
TAKOSUMI_DEPLOY_CONTROL_TOKEN=local-substrate-deploy-control-token
TAKOSUMI_DEPLOY_TOKEN=local-substrate-deploy-token

# Takosumi internal callback secret. Local-dev fixture only.
TAKOSUMI_INTERNAL_API_SECRET=local-dev-secret

# Optional local provider credentials. Prefer creating Space Provider
# Connections through the dashboard/API. These env vars are for local adapter
# experiments only and must not be copied to production.
#
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# GCP_PROJECT=
# GCP_SERVICE_ACCOUNT_KEY_JSON=
#
# AZURE_SUBSCRIPTION_ID=
# AZURE_BEARER_TOKEN=
#
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
#
# KUBE_API_SERVER_URL=
# KUBE_BEARER_TOKEN=
