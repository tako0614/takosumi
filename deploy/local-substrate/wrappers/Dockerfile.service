# Service container for local-substrate.
#
# Base: oven/bun (matches the Bun-first local-substrate runtime).
# Adds: docker CLI + compose implementation so the embedded runtime-agent's
# Docker Compose handler can spawn `docker compose` against
# the host docker socket mounted at /var/run/docker.sock.
#
# Source mounts: handled by docker compose; the wrapper script and the
# takosumi/ workspace are bind-mounted at runtime, this image only
# carries the binaries.
FROM oven/bun:1

# Pull docker CLI (no daemon) from the official docker image. Compose
# implementation lives under cli-implementations/ in the same image.
COPY --from=docker:29-cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=docker:29-cli /usr/local/libexec/docker/cli-implementations /usr/local/libexec/docker/cli-implementations

# Sanity check at build time.
RUN docker --version && docker compose version
