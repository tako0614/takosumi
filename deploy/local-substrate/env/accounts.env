# Takosumi Accounts (OIDC issuer, postgres-backed) env block for
# local-substrate. Production deploys must NEVER copy this file:
# MANAGED_OFFERING_ACCESS is 'closed' on purpose so the gate logic itself
# is exercised in negative form.
#
# Each line is `KEY=value` (compose env_file syntax, no quoting of
# values). Inline `#` comments are NOT supported by docker compose
# env_file — keep comments on dedicated lines.

PORT=8787
TAKOSUMI_ACCOUNTS_BIND_HOST=0.0.0.0
TAKOSUMI_ACCOUNTS_ISSUER=https://app.takosumi.test
TAKOSUMI_ACCOUNTS_DATABASE_URL=postgres://takos:takos@postgres:5432/takosumi_accounts
TAKOSUMI_ACCOUNTS_CLIENT_ID=takosumi-local-dashboard
TAKOSUMI_ACCOUNTS_REDIRECT_URIS=https://app.takosumi.test/sign-in/callback
TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_ACCESS=closed
TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICE_RESOLVER_TOKEN=local-substrate-platform-service-token
TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICES_ALLOW_DIRECT_DEPLOY_CONTROL=true
TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICES_INTERNAL_URL=http://accounts:8787
TAKOSUMI_ACCOUNTS_BILLING_PORTAL_URL=https://app.takosumi.test/account/billing
