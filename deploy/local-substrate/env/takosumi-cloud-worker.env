# takosumi-cloud-worker (miniflare + D1/R2) env block for local-substrate.
# Production deploys must NEVER copy this file: managed-offering is OPEN
# and SECRET_KEY values are fixture placeholders.
#
# Each line is `KEY=value` (compose env_file syntax, no quoting of values).
# Inline `#` comments are NOT supported by docker compose env_file — keep
# comments on dedicated lines.

# ----- Runtime self-identification -----------------------------------------
WORKER_SCRIPT=/worker/takosumi-cloud-accounts-worker.mjs
WORKER_PORT=8787
LOCAL_SUBSTRATE_TEST_BED=1
TAKOSUMI_ACCOUNTS_ISSUER=https://cloud.takosumi.test
TAKOSUMI_ACCOUNTS_SUBJECT=tsub_takosumi_cloud_local
TAKOSUMI_ACCOUNTS_CLIENT_ID=takos-app-local
TAKOSUMI_ACCOUNTS_REDIRECT_URIS=https://app.takos.test/oauth/callback https://cloud.takosumi.test/sign-in/callback

# ----- Managed-offering gate (open, with local-only fixture evidence) ------
# READINESS_DIGEST is sha256 of docs/launch-readiness/p0-local-evidence.md —
# the actual fixture file checked into this repo, not an opaque magic string.
# Regenerate with `sha256sum docs/launch-readiness/p0-local-evidence.md`
# whenever the fixture changes. The handler.ts guard refuses 'open' on a
# production-looking issuer unless LOCAL_OVERRIDE=1 is also set.
TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_ACCESS=open
TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_READINESS_DIGEST=sha256:6263abc3f61bbd6b17b3c28adfaedbef9b9647cd92d947f4818b6de381e802a6
TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_EVIDENCE_REF=git+https://github.com/tako0614/takosumi.git#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md
TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_APPROVAL_REF=git+https://github.com/tako0614/takosumi.git#deploy/local-substrate/docs/launch-readiness/p0-local-approval.md
TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_PUBLIC_SUMMARY=Local substrate p0 staged rehearsal — evidence retained with rehearsal log; no production traffic served.

# ----- Install preview --------------------------------------------------
TAKOSUMI_ACCOUNTS_INSTALL_PREVIEW_URL=http://install-preview-mock:8788

# ----- Metadata-only export downloads ----------------------------------
TAKOSUMI_ACCOUNTS_EXPORT_DOWNLOAD_SECRET=local-substrate-export-download-secret-v1
TAKOSUMI_ACCOUNTS_EXPORT_DOWNLOAD_TTL_MS=86400000

# ----- Upstream OAuth (Google / GitHub) ---------------------------------
# /token + /userinfo are HTTP (not HTTPS) inside docker network because
# workerd's TLS trust store doesn't have Pebble root. Negative-path
# coverage: scripts/oauth-tls-negative.sh
TAKOSUMI_ACCOUNTS_SUBJECT_SECRET=local-substrate-upstream-subject-secret-v1
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_CLIENT_ID=takos-cloud-local-google
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_CLIENT_SECRET=mock-secret-google
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_REDIRECT_URI=https://cloud.takosumi.test/sign-in/callback
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_ISSUER=https://oauth-mock.test/google
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_AUTHORIZATION_ENDPOINT=https://oauth-mock.test/google/authorize
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_TOKEN_ENDPOINT=http://oauth-mock:8789/google/token
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_USERINFO_ENDPOINT=http://oauth-mock:8789/google/userinfo
TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_CLIENT_ID=takos-cloud-local-github
TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_CLIENT_SECRET=mock-secret-github
TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_REDIRECT_URI=https://cloud.takosumi.test/sign-in/callback
TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_ISSUER=https://oauth-mock.test/github
TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_AUTHORIZATION_ENDPOINT=https://oauth-mock.test/github/authorize
TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_TOKEN_ENDPOINT=http://oauth-mock:8789/github/access_token
TAKOSUMI_ACCOUNTS_UPSTREAM_GITHUB_USERINFO_ENDPOINT=http://oauth-mock:8789/github/user

# ----- Custom OIDC slot for TLS-error negative test ---------------------
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_PROVIDER_ID=tls-fail
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_ISSUER=https://oauth-mock.test/tls-fail
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_AUTHORIZATION_ENDPOINT=https://oauth-mock.test/tls-fail/authorize
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_TOKEN_ENDPOINT=http://oauth-mock:8789/tls-fail/token
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_USERINFO_ENDPOINT=http://oauth-mock:8789/tls-fail/userinfo
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_CLIENT_ID=takos-cloud-local-tls-fail
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_CLIENT_SECRET=mock-secret-tls-fail
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_REDIRECT_URI=https://cloud.takosumi.test/sign-in/callback
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_SUBJECT_CLAIM=sub

# ----- Passkey RP -------------------------------------------------------
TAKOSUMI_ACCOUNTS_PASSKEY_RP_ID=cloud.takosumi.test
TAKOSUMI_ACCOUNTS_PASSKEY_RP_NAME=Takosumi Cloud (local)
TAKOSUMI_ACCOUNTS_PASSKEY_ORIGIN=https://cloud.takosumi.test

# ----- Stripe billing (local fixtures) -----------------------------------
TAKOSUMI_ACCOUNTS_STRIPE_SECRET_KEY=sk_test_local_substrate_fixture
TAKOSUMI_ACCOUNTS_STRIPE_WEBHOOK_SECRET=whsec_local_substrate_fixture_v1
