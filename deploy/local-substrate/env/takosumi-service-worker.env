# Composed Takosumi platform worker (Miniflare + D1/R2/DO/queue) env block for
# local-substrate. This boots deploy/platform/worker.ts — the SAME composed
# entry the operator deploys at app.takosumi.com (accounts plane + in-process
# deploy-control plane) — replacing the old two-bundle scaffold.
#
# Production deploys must NEVER copy this file. Use
# deploy/platform/wrangler.toml + `wrangler secret put` instead. hosted Takosumi
# access is OPEN here only because of the local-only fixture evidence below, and
# every SECRET value is a fixture placeholder.
#
# Each line is `KEY=value` (compose env_file syntax, no quoting of values).
# Inline `#` comments are NOT supported by docker compose env_file — keep
# comments on dedicated lines.

# ----- Runtime self-identification -----------------------------------------
LOCAL_SUBSTRATE_TEST_BED=1
WORKER_SCRIPT=/worker/takosumi-platform-worker.mjs
WORKER_PORT=8788
WORKER_COMPATIBILITY_DATE=2026-04-15

TAKOSUMI_RUNTIME_MODE=cloudflare-worker
TAKOSUMI_ENVIRONMENT=development
TAKOSUMI_DEPLOY_CONTROL_TOKEN=local-substrate-deploy-control-token
TAKOSUMI_DEPLOY_TOKEN=local-substrate-deploy-token
TAKOSUMI_DEPLOY_SPACE_ID=local-substrate-space
TAKOSUMI_INTERNAL_API_SECRET=local-dev-secret
TAKOSUMI_SECRET_STORE_PASSPHRASE=local-substrate-secret-store-passphrase-v1

# ----- Accounts plane identity ---------------------------------------------
TAKOSUMI_ACCOUNTS_ISSUER=https://app.takosumi.test
TAKOSUMI_ACCOUNTS_SUBJECT=tsub_takosumi_accounts_local
TAKOSUMI_ACCOUNTS_LOCAL_DEV_SUBJECT=tsub_takosumi_accounts_local
TAKOSUMI_ACCOUNTS_LOCAL_DEV_SESSION_ID=sess_local_substrate
TAKOSUMI_ACCOUNTS_LOCAL_DEV_ACCOUNT_ID=acct_local
TAKOSUMI_ACCOUNTS_LOCAL_DEV_SPACE_ID=space_local
TAKOSUMI_ACCOUNTS_CLIENT_ID=takosumi-local
TAKOSUMI_ACCOUNTS_REDIRECT_URIS=https://app.takosumi.test/sign-in/callback

# ----- hosted Takosumi access gate (open, with local-only fixture evidence) ------
# READINESS_DIGEST and the hardening evidence digests are sha256 of
# docs/launch-readiness/p0-local-evidence.md — the actual fixture file checked
# into this repo, not opaque magic strings.
# Regenerate with `sha256sum docs/launch-readiness/p0-local-evidence.md`
# whenever the fixture changes. The handler.ts guard refuses 'open' on a
# production-looking issuer unless readiness + hardening evidence vars are set.
TAKOSUMI_ACCOUNTS_PLATFORM_ACCESS=open
TAKOSUMI_ACCOUNTS_PLATFORM_READINESS_DIGEST=sha256:da3371ba1819fdc62c90ad346c5523d3e678e253f4b34595f4a8e50ef39dbe4d
TAKOSUMI_ACCOUNTS_PLATFORM_EVIDENCE_REF=git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md
TAKOSUMI_ACCOUNTS_PLATFORM_APPROVAL_REF=git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-approval.md
TAKOSUMI_ACCOUNTS_PLATFORM_PUBLIC_SUMMARY=Local substrate p0 staged rehearsal - evidence retained with rehearsal log; no production traffic served.
TAKOSUMI_PRODUCTION_HARDENING_GATE=enforce
TAKOSUMI_CLOUDFLARE_CONTAINER_SMOKE_EVIDENCE_REF=git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md
TAKOSUMI_CLOUDFLARE_CONTAINER_SMOKE_EVIDENCE_DIGEST=sha256:da3371ba1819fdc62c90ad346c5523d3e678e253f4b34595f4a8e50ef39dbe4d
TAKOSUMI_EGRESS_ENFORCEMENT_EVIDENCE_REF=git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md
TAKOSUMI_EGRESS_ENFORCEMENT_EVIDENCE_DIGEST=sha256:da3371ba1819fdc62c90ad346c5523d3e678e253f4b34595f4a8e50ef39dbe4d
TAKOSUMI_PROVIDER_REGISTRY_EVIDENCE_REF=git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md
TAKOSUMI_PROVIDER_REGISTRY_EVIDENCE_DIGEST=sha256:da3371ba1819fdc62c90ad346c5523d3e678e253f4b34595f4a8e50ef39dbe4d
TAKOSUMI_SECRET_BOUNDARY_EVIDENCE_REF=git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md
TAKOSUMI_SECRET_BOUNDARY_EVIDENCE_DIGEST=sha256:da3371ba1819fdc62c90ad346c5523d3e678e253f4b34595f4a8e50ef39dbe4d

# ----- Platform services ----------------------------------------------------
# The composed worker resolves the service graph in-process, so no external
# resolver URL is needed. The token stays available for in-process material
# resolution parity with production.
TAKOSUMI_ACCOUNTS_SERVICE_GRAPH_MATERIAL_RESOLVER_TOKEN=local-substrate-platform-service-token
TAKOSUMI_ACCOUNTS_BILLING_PORTAL_URL=https://app.takosumi.test/account/billing

# ----- Metadata-only export downloads ----------------------------------
TAKOSUMI_ACCOUNTS_EXPORT_DOWNLOAD_SECRET=local-substrate-export-download-secret-v1
TAKOSUMI_ACCOUNTS_EXPORT_DOWNLOAD_TTL_MS=86400000
TAKOSUMI_ACCOUNTS_PRIVACY_OPERATIONS_TOKEN=local-substrate-privacy-operations-token-v1

# ----- Upstream OAuth (Google) ------------------------------------------
# /token + /userinfo are HTTP (not HTTPS) inside docker network because
# workerd's TLS trust store doesn't have Pebble root. Negative-path
# coverage: scripts/oauth-tls-negative.sh
TAKOSUMI_ACCOUNTS_SUBJECT_SECRET=local-substrate-upstream-subject-secret-v1
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_CLIENT_ID=takos-cloud-local-google
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_CLIENT_SECRET=mock-secret-google
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_REDIRECT_URI=https://app.takosumi.test/sign-in/callback
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_ISSUER=https://oauth-mock.test/google
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_AUTHORIZATION_ENDPOINT=https://oauth-mock.test/google/authorize
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_TOKEN_ENDPOINT=http://oauth-mock:8789/google/token
TAKOSUMI_ACCOUNTS_UPSTREAM_GOOGLE_USERINFO_ENDPOINT=http://oauth-mock:8789/google/userinfo

# ----- Custom OIDC slot for TLS-error negative test ---------------------
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_PROVIDER_ID=tls-fail
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_ISSUER=https://oauth-mock.test/tls-fail
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_AUTHORIZATION_ENDPOINT=https://oauth-mock.test/tls-fail/authorize
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_TOKEN_ENDPOINT=http://oauth-mock:8789/tls-fail/token
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_USERINFO_ENDPOINT=http://oauth-mock:8789/tls-fail/userinfo
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_CLIENT_ID=takos-cloud-local-tls-fail
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_CLIENT_SECRET=mock-secret-tls-fail
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_REDIRECT_URI=https://app.takosumi.test/sign-in/callback
TAKOSUMI_ACCOUNTS_UPSTREAM_OIDC_SUBJECT_CLAIM=sub

# ----- Passkey RP -------------------------------------------------------
TAKOSUMI_ACCOUNTS_PASSKEY_RP_ID=app.takosumi.test
TAKOSUMI_ACCOUNTS_PASSKEY_RP_NAME=Takosumi (local)
TAKOSUMI_ACCOUNTS_PASSKEY_ORIGIN=https://app.takosumi.test

# ----- Stripe billing (local fixtures) -----------------------------------
TAKOSUMI_ACCOUNTS_STRIPE_SECRET_KEY=sk_test_local_substrate_fixture
TAKOSUMI_ACCOUNTS_STRIPE_WEBHOOK_SECRET=whsec_local_substrate_fixture_v1
