# Composed Takosumi platform worker (Miniflare + D1/R2/DO/queue) env block for
# local-substrate. This boots deploy/platform/worker.ts — the SAME composed
# entry the operator deploys at app.takosumi.com (accounts plane + in-process
# deploy-control plane) — replacing the old two-bundle scaffold.
#
# Production deploys must NEVER copy this file. Use
# deploy/platform/wrangler.toml + `wrangler secret put` instead. hosted Takosumi
# access is OPEN here only because of the local-only fixture evidence below, and
# every SECRET value is a fixture placeholder.
#
# Each line is `KEY=value` (compose env_file syntax, no quoting of values).
# Inline `#` comments are NOT supported by docker compose env_file — keep
# comments on dedicated lines.

# ----- Runtime self-identification -----------------------------------------
LOCAL_SUBSTRATE_TEST_BED=1
WORKER_SCRIPT=/worker/takosumi-platform-worker.mjs
WORKER_PORT=8788
WORKER_COMPATIBILITY_DATE=2026-04-15
WORKER_OUTBOUND_CA_CERT_PATH=/local-substrate-runtime/pebble-issuance-root.pem
WORKER_ACCOUNTS_D1_MIGRATIONS_PATH=/worker/takosumi-accounts-d1-migrations.json

TAKOSUMI_RUNTIME_MODE=cloudflare-worker
TAKOSUMI_ENVIRONMENT=development
TAKOSUMI_DEPLOY_CONTROL_TOKEN=local-substrate-deploy-control-token
TAKOSUMI_EXPOSE_INTERNAL_EDGE=1
TAKOSUMI_LOCAL_OPENTOFU_RUNNER_URL=http://opentofu-runner:8080
TAKOSUMI_DEPLOY_SPACE_ID=local-substrate-space
TAKOSUMI_INTERNAL_API_SECRET=local-dev-secret
TAKOSUMI_SECRET_STORE_PASSPHRASE=local-substrate-secret-store-passphrase-v1

# ----- Accounts plane identity ---------------------------------------------
TAKOSUMI_ACCOUNTS_ISSUER=https://app.takosumi.test
TAKOSUMI_ACCOUNTS_SUBJECT=tsub_takosumi_accounts_local
TAKOSUMI_ACCOUNTS_LOCAL_DEV_SUBJECT=tsub_takosumi_accounts_local
TAKOSUMI_ACCOUNTS_LOCAL_DEV_SESSION_ID=sess_local_substrate
TAKOSUMI_ACCOUNTS_CLIENT_ID=takosumi-local
TAKOSUMI_ACCOUNTS_REDIRECT_URIS=https://app.takosumi.test/sign-in/callback
TAKOSUMI_ACCOUNTS_CLIENTS=[{"clientId":"takosumi-local","redirectUris":["https://app.takosumi.test/sign-in/callback"],"tokenEndpointAuthMethod":"none"},{"clientId":"takos-mobile-takos-local","redirectUris":["takos://oauth/callback"],"tokenEndpointAuthMethod":"none","allowedScopes":["openid","profile","offline_access","spaces:read","spaces:write","threads:read","threads:write","runs:read","runs:write","agents:execute","memories:read","memories:write"]}]

# ----- production hardening (local-only fixture evidence) ----------------
# The hardening evidence digests are sha256 of docs/launch-readiness/
# p0-local-evidence.md — the actual fixture file checked into this repo.
# Regenerate with `sha256sum docs/launch-readiness/p0-local-evidence.md`
# whenever the fixture changes.
TAKOSUMI_PRODUCTION_HARDENING_GATE=enforce
TAKOSUMI_PLATFORM_HARDENING_EVIDENCE={"kind":"takosumi.platform-hardening-gate-evidence@v1","contributions":[{"id":"takosumi-oss","capability":"platform.hardening.oss-baseline.v1","checks":[{"id":"runner-execution-smoke","evidenceRef":"git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md","evidenceDigest":"sha256:64e2e6dc574ab3b202eea7ecea9195e2764e3b839df3b10e4c603e04cb0d906d"},{"id":"capsule-lifecycle-smoke","evidenceRef":"git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md","evidenceDigest":"sha256:64e2e6dc574ab3b202eea7ecea9195e2764e3b839df3b10e4c603e04cb0d906d"},{"id":"egress-enforcement","evidenceRef":"git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md","evidenceDigest":"sha256:64e2e6dc574ab3b202eea7ecea9195e2764e3b839df3b10e4c603e04cb0d906d"},{"id":"restore-rehearsal","evidenceRef":"git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md","evidenceDigest":"sha256:64e2e6dc574ab3b202eea7ecea9195e2764e3b839df3b10e4c603e04cb0d906d"},{"id":"credential-recipe-boundary","evidenceRef":"git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md","evidenceDigest":"sha256:64e2e6dc574ab3b202eea7ecea9195e2764e3b839df3b10e4c603e04cb0d906d"},{"id":"secret-boundary","evidenceRef":"git+https://github.com/tako0614/takosumi.git@0123456789abcdef0123456789abcdef01234567#deploy/local-substrate/docs/launch-readiness/p0-local-evidence.md","evidenceDigest":"sha256:64e2e6dc574ab3b202eea7ecea9195e2764e3b839df3b10e4c603e04cb0d906d"}]}]}

TAKOSUMI_ACCOUNTS_PRIVACY_OPERATIONS_TOKEN=local-substrate-privacy-operations-token-v1
# Deliberate local-only/non-production signing fixture, shared with cloud.env.
TAKOSUMI_ACCOUNTS_ES256_PRIVATE_JWK={"kty":"EC","crv":"P-256","d":"MxLuR_Vh9AOJ134l9hOo9-AG0blordOUV101A1xnVpY","x":"IcEBfrFfO2ChFPPa6tI-ro1IL7Cbdyi3eVciVAYjYbo","y":"EAarhgJ5UEpJaTpMK4U46S9vpCiqOH9j8lBzcsU2yTE"}
TAKOSUMI_ACCOUNTS_OIDC_PAIRWISE_SUBJECT_SECRET=local-substrate-oidc-pairwise-subject-secret-fixture

# ----- Generic upstream OAuth fixtures ---------------------------------
# /token + /userinfo stay HTTPS. The local-only Miniflare runner adds Pebble's
# issuance root to workerd's outbound trust store without disabling normal TLS
# verification. Negative-path coverage: scripts/workerd-tls-negative.sh
TAKOSUMI_ACCOUNTS_SUBJECT_SECRET=local-substrate-upstream-subject-secret-v1
TAKOSUMI_ACCOUNTS_UPSTREAM_PROVIDERS=[{"providerId":"local-oidc","label":"Local OIDC","issuer":"https://oauth-mock.test/local-oidc","authorizationEndpoint":"https://oauth-mock.test/local-oidc/authorize","tokenEndpoint":"https://oauth-mock.test/local-oidc/token","userInfoEndpoint":"https://oauth-mock.test/local-oidc/userinfo","clientId":"takos-cloud-local-oidc","clientSecretEnv":"TAKOSUMI_LOCAL_OIDC_CLIENT_SECRET","redirectUri":"https://app.takosumi.test/sign-in/callback","scopes":["openid","profile","email"]},{"providerId":"tls-fail","label":"TLS failure fixture","issuer":"https://oauth-mock.test/tls-fail","authorizationEndpoint":"https://oauth-mock.test/tls-fail/authorize","tokenEndpoint":"https://oauth-mock.test/tls-fail/token","userInfoEndpoint":"https://oauth-mock.test/tls-fail/userinfo","clientId":"takos-cloud-local-tls-fail","clientSecretEnv":"TAKOSUMI_LOCAL_TLS_FAIL_CLIENT_SECRET","redirectUri":"https://app.takosumi.test/sign-in/callback","subjectClaim":"sub"}]
TAKOSUMI_LOCAL_OIDC_CLIENT_SECRET=mock-secret-local-oidc
TAKOSUMI_LOCAL_TLS_FAIL_CLIENT_SECRET=mock-secret-tls-fail

# ----- Passkey RP -------------------------------------------------------
TAKOSUMI_ACCOUNTS_PASSKEY_RP_ID=app.takosumi.test
TAKOSUMI_ACCOUNTS_PASSKEY_RP_NAME=Takosumi (local)
TAKOSUMI_ACCOUNTS_PASSKEY_ORIGIN=https://app.takosumi.test
