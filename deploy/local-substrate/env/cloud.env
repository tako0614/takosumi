# Redesigned local-substrate `cloud` control plane (postgres profile).
#
# ONE composed app = Takosumi Accounts (OIDC issuer, billing, dashboard,
# install UI) + the embedded Takosumi service. This mirrors production's single
# app.takosumi.com — there is no separate accounts/service host anymore.
# Execution is dispatched to the external `agent` service over
# TAKOSUMI_AGENT_URL/TOKEN; this process holds no docker.sock.
#
# Production deploys must NEVER copy this file:
#   - MANAGED_OFFERING_ACCESS=closed exercises the gate in negative form
#   - TAKOSUMI_DEPLOY_CONTROL_TOKEN / TAKOSUMI_DEPLOY_TOKEN are fixtures
#   - TAKOSUMI_INTERNAL_API_SECRET / TAKOSUMI_DEV_MODE=1 are local-dev only
#
# compose env_file syntax: `KEY=value` per line, no value quoting, and inline
# `#` comments are NOT supported — keep comments on dedicated lines.

PORT=8787
TAKOSUMI_ACCOUNTS_BIND_HOST=0.0.0.0
TAKOSUMI_ACCOUNTS_ISSUER=https://app.takosumi.test
TAKOSUMI_ACCOUNTS_DATABASE_URL=postgres://takos:takos@postgres:5432/takosumi_accounts
TAKOSUMI_ACCOUNTS_CLIENT_ID=takosumi-local-dashboard
TAKOSUMI_ACCOUNTS_REDIRECT_URIS=https://app.takosumi.test/sign-in/callback
TAKOSUMI_ACCOUNTS_MANAGED_OFFERING_ACCESS=closed
TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICE_RESOLVER_TOKEN=local-substrate-platform-service-token
TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICES_ALLOW_DIRECT_DEPLOY_CONTROL=true
TAKOSUMI_ACCOUNTS_WORKLOAD_PLATFORM_SERVICES_INTERNAL_URL=http://cloud:8787
TAKOSUMI_ACCOUNTS_BILLING_PORTAL_URL=https://app.takosumi.test/account/billing

# Stable OIDC signing key. app.takosumi.test is an https issuer, and the
# account plane refuses to boot an https issuer on an ephemeral per-process key
# (it breaks id_token verification across restart / scale). This is a FIXTURE
# dev key (shared with the cloudflare worker tests) — production deploys mint
# their own and must NEVER reuse this one.
TAKOSUMI_ACCOUNTS_ES256_PRIVATE_JWK={"kty":"EC","crv":"P-256","d":"MxLuR_Vh9AOJ134l9hOo9-AG0blordOUV101A1xnVpY","x":"IcEBfrFfO2ChFPPa6tI-ro1IL7Cbdyi3eVciVAYjYbo","y":"EAarhgJ5UEpJaTpMK4U46S9vpCiqOH9j8lBzcsU2yTE"}
TAKOSUMI_ACCOUNTS_OIDC_PAIRWISE_SUBJECT_SECRET=local-substrate-oidc-pairwise-subject-secret-fixture
TAKOSUMI_ACCOUNTS_LAUNCH_TOKEN_PAIRWISE_SECRET=local-substrate-launch-token-pairwise-secret-fixture

# --- embedded Takosumi service ---
# v1 ships the in-memory service ledger (composed-app.ts documents this as fine
# for dev / local-substrate when no sqlClient is passed), so no
# TAKOSUMI_DATABASE_URL / auto-migrate here. Durable Postgres ledger is an
# additive follow-up.
TAKOSUMI_ENVIRONMENT=development
TAKOSUMI_DEPLOY_CONTROL_TOKEN=local-substrate-deploy-control-token
TAKOSUMI_DEPLOY_TOKEN=local-substrate-deploy-token
TAKOSUMI_INTERNAL_API_SECRET=local-dev-secret
TAKOSUMI_DEV_MODE=1

# --- external runtime-agent (execution plane) ---
# The service bootstrap reads these and dispatches source / lifecycle /
# capability execution to the `agent` service. TAKOSUMI_AGENT_TOKEN MUST match
# env/agent.env.
TAKOSUMI_AGENT_URL=http://agent:8789
TAKOSUMI_AGENT_TOKEN=local-substrate-agent-token

# --- CoreDNS gateway projection (in-process implementation binding -> Caddy runtime) ---
TAKOSUMI_LOCAL_SUBSTRATE_GATEWAY_ROUTES_FILE=/local-substrate-runtime/gateway-routes.json
TAKOSUMI_LOCAL_SUBSTRATE_GATEWAY_HOST=takos.app.takosumi.test
TAKOSUMI_LOCAL_SUBSTRATE_INGRESS_IP=127.0.0.1
