# Redesigned local-substrate `agent` execution plane (postgres profile).
#
# Runs the takosumi runtime-agent (`serveRuntimeAgent`) with docker.sock +
# subprocess privilege. The `cloud` control plane dispatches source / lifecycle
# / capability execution here over TAKOSUMI_AGENT_URL. Splitting execution off
# the control plane mirrors production (a Workers control plane cannot embed a
# subprocess agent) and isolates host-execution privilege.
#
# Production deploys must NEVER copy this file (fixtures, DEV_MODE, host socket).
#
# compose env_file syntax: `KEY=value` per line, no value quoting, and inline
# `#` comments are NOT supported — keep comments on dedicated lines.

TAKOSUMI_AGENT_PORT=8789
TAKOSUMI_AGENT_HOSTNAME=0.0.0.0
TAKOSUMI_AGENT_TOKEN=local-substrate-agent-token
TAKOSUMI_ENVIRONMENT=development
TAKOSUMI_DEV_MODE=1

# --- operator-owned adapter config consumed by custom connector registries ---
TAKOSUMI_LOCAL_ADAPTER_OBJECT_STORE_ENDPOINT=http://minio:9000
TAKOSUMI_LOCAL_ADAPTER_DOCKER_SOCKET=/var/run/docker.sock
TAKOSUMI_LOCAL_ADAPTER_DOCKER_HOST_BINDING=host.docker.internal
TAKOSUMI_LOCAL_ADAPTER_DOCKER_ADD_HOSTS=host.docker.internal:host-gateway
TAKOSUMI_LOCAL_ADAPTER_DOCKER_NETWORK=local-substrate_takos-local-internal
TAKOSUMI_LOCAL_ADAPTER_POSTGRES_HOST=host.docker.internal
TAKOSUMI_LOCAL_ADAPTER_POSTGRES_AUTH_MODE=trust
