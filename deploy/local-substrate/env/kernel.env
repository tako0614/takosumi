# Takosumi kernel env block for local-substrate (postgres profile,
# embedded runtime-agent in-process).
#
# Production deploys must NEVER copy this file:
#   - TAKOSUMI_DEPLOY_TOKEN is a fixture
#   - TAKOSUMI_INTERNAL_API_SECRET is local-dev only
#   - TAKOSUMI_DEV_MODE=1 enables non-prod codepaths
#   - TAKOSUMI_DB_AUTO_MIGRATE=true unsafe in prod
#
# These were previously inlined as ${VAR:-default} so they could be
# overridden by the operator's shell env. The override hook is dropped
# because (a) nothing in this repo actually overrides them, (b) env_file
# does not support compose-style ${VAR:-default} expansion. Override by
# editing this file directly if needed.

PORT=8788
TAKOSUMI_ENVIRONMENT=development
TAKOSUMI_DATABASE_URL=postgres://takos:takos@postgres:5432/takosumi
DATABASE_URL=postgres://takos:takos@postgres:5432/takosumi
TAKOSUMI_DEPLOY_TOKEN=local-substrate-deploy-token
TAKOSUMI_INTERNAL_API_SECRET=local-dev-secret
TAKOSUMI_DEV_MODE=1
TAKOSUMI_DB_AUTO_MIGRATE=true
TAKOSUMI_SELFHOSTED_OBJECT_STORE_ENDPOINT=http://minio:9000
TAKOSUMI_SELFHOSTED_DOCKER_SOCKET=/var/run/docker.sock
