# takos-app env block for local-substrate.
#
# takos-app uses the local-platform package (Postgres + Redis + libsql)
# instead of the apps/api Deno entry which expects D1 bindings.
# Entry: takos/app/apps/control/deno.json → dev:local:web →
#   packages/control/local-platform/src/web.ts
#
# Each line is `KEY=value` (compose env_file syntax, no quoting).
# Inline `#` comments not supported.

PORT=8787
ADMIN_DOMAIN=app.takos.test
TENANT_BASE_DOMAIN=app.takos.test
AUTH_PUBLIC_BASE_URL=https://app.takos.test
OIDC_ISSUER_URL=https://accounts.takos.test
OIDC_CLIENT_ID=takos-app
OIDC_REDIRECT_URI=https://app.takos.test/oauth/callback
OIDC_CLIENT_SECRET=local-substrate-oidc-client-secret
TAKOS_LOCAL_DATA_DIR=/var/lib/takos-local-substrate
TAKOS_LOCAL_DATABASE_URL=postgres://takos:takos@postgres:5432/takos_app
REDIS_URL=redis://redis:6379
TAKOS_INTERNAL_SERVICE_SECRET=local-dev-secret
