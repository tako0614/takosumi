# yurucommu instance A env block for local-substrate federation smoke.
# Pair with env/yurucommu-b.env — only APP_URL differs between the two.

PORT=8791
APP_URL=https://inst-a.takos.test
DATABASE_PATH=/data/yurucommu.db
STORAGE_PATH=/data/storage
NODE_ENV=development
# PBKDF2-SHA256 hash of "local-substrate-fixture-password-v1" with a
# fixed 0xaa…0xaa salt (deterministic so the federation smoke can
# `POST /api/auth/login` with a known password without re-running a
# hash generator). Production must use a random salt + secret password.
AUTH_PASSWORD_HASH=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa:25a88f565411ba61ea5e312eee82e0dbff237673435173ccc3598cc7c241a3ea
# 32-byte hex key for session encryption. Fixture value — production
# rotates this on every deploy.
ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
# Trust the Pebble root so Deno fetch() can validate the peer instance's
# HTTPS cert during federation actor lookup (see compose volumes mount).
DENO_CERT=/etc/ssl/pebble-root.pem
# Local-substrate only: allow HTTPS *.takos.test federation fetches that
# resolve to loopback/Docker bridge IPs, and drain delivery jobs without
# Cloudflare Queue bindings in the Deno server.
YURUCOMMU_ENABLE_LOCAL_SUBSTRATE_REMOTE_FETCHES=true
YURUCOMMU_ENABLE_DENO_DELIVERY_QUEUE=true
