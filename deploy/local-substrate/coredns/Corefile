takosumi.test:53 {
    file /etc/coredns/zones/takosumi.test.zone
    log
    errors
}

oauth-mock.test:53 {
    file /etc/coredns/zones/oauth-mock.test.zone
    log
    errors
}

# Defense in depth: NXDOMAIN any *.letsencrypt.org query so a
# misconfigured Caddy can't fall back to public ACME prod even if the
# Caddyfile pin is later removed.
letsencrypt.org:53 {
    template ANY ANY {
        rcode NXDOMAIN
    }
    log
    errors
}

. {
    forward . 1.1.1.1 8.8.8.8
    cache 30
    log
    errors
}
