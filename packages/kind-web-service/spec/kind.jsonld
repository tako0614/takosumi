{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/web-service",
  "@type": "ComponentKind",
  "name": "web-service",
  "version": "v1",
  "referenceAliases": [
    "web-service"
  ],
  "description": "Long-running HTTP service backed by an OCI image.",
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
      "image",
      "port"
    ],
    "additionalProperties": false,
    "properties": {
      "image": {
        "type": "string",
        "minLength": 1,
        "description": "OCI image reference."
      },
      "port": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535,
        "description": "Container listen port exposed by the service."
      },
      "scale": {
        "type": "object",
        "required": [
          "min",
          "max"
        ],
        "additionalProperties": false,
        "description": "Replica bounds. `min: 0` requests zero steady replicas. Operator policy and the selected implementation materialize or reject the request.",
        "properties": {
          "min": {
            "type": "integer",
            "minimum": 0,
            "description": "Minimum requested replica count."
          },
          "max": {
            "type": "integer",
            "minimum": 1,
            "description": "Maximum requested replica count."
          }
        }
      },
      "env": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Environment variables passed to the service."
      },
      "resources": {
        "type": "object",
        "additionalProperties": false,
        "description": "CPU / memory hints consumed by compatible provider bindings.",
        "properties": {
          "cpu": {
            "type": "string",
            "minLength": 1,
            "description": "Requested CPU size or provider-specific CPU class."
          },
          "memory": {
            "type": "string",
            "minLength": 1,
            "description": "Requested memory size or provider-specific memory class."
          }
        }
      }
    }
  },
  "outputSlots": {
    "http": {
      "contract": "http-endpoint",
      "exampleMaterialMapping": {
        "targets": [
          {
            "name": "default",
            "url": "$outputs.url",
            "host": "$outputs.internalHost",
            "port": "$outputs.internalPort",
            "visibility": "private"
          }
        ]
      }
    }
  },
  "listens": {
    "*": {
      "accepts": [
        "http-endpoint",
        "service-binding",
        "object-store",
        "event-channel",
        "identity.oidc@v1",
        "billing.port@v1"
      ],
      "projectionFamilies": [
        "env",
        "secret-env",
        "config-mount",
        "upstream"
      ],
      "projectionMatrix": {
        "http-endpoint": [
          "env",
          "config-mount",
          "upstream"
        ],
        "service-binding": [
          "secret-env",
          "config-mount"
        ],
        "object-store": [
          "secret-env",
          "config-mount"
        ],
        "event-channel": [
          "secret-env",
          "config-mount"
        ],
        "identity.oidc@v1": [
          "secret-env",
          "config-mount"
        ],
        "billing.port@v1": [
          "secret-env",
          "config-mount"
        ]
      }
    }
  },
  "outputs": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "meaning": "Implementation-local upstream URL (scheme-bearing) used by gateway/listener components."
    },
    {
      "name": "internalHost",
      "type": "string",
      "required": true,
      "meaning": "Implementation-local service host."
    },
    {
      "name": "internalPort",
      "type": "integer",
      "required": true,
      "meaning": "Implementation-local service port."
    }
  ],
  "capabilityTerms": [
    "http-service",
    "oci-image",
    "replica-scaling"
  ]
}
