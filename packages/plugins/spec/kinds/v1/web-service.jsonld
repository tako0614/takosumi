{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/web-service",
  "@type": "ComponentKind",
  "name": "web-service",
  "version": "v1",
  "referenceAliases": ["web-service"],
  "description": "Long-running HTTP service backed by an OCI image.",
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["image", "port", "scale"],
    "additionalProperties": true,
    "properties": {
      "image": {
        "type": "string",
        "minLength": 1,
        "description": "OCI image reference."
      },
      "port": {
        "type": "integer",
        "minimum": 1,
        "description": "Container listen port exposed by the service."
      },
      "scale": {
        "type": "object",
        "required": ["min", "max"],
        "additionalProperties": false,
        "description": "Replica bounds. `min: 0` requests scale-to-zero. Operator policy and the selected implementation materialize or reject the request.",
        "properties": {
          "min": { "type": "integer", "minimum": 0 },
          "max": { "type": "integer", "minimum": 1 }
        }
      },
      "env": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Environment variables passed to the service."
      },
      "resources": {
        "type": "object",
        "additionalProperties": false,
        "description": "CPU / memory hints consumed by compatible provider bindings.",
        "properties": {
          "cpu": { "type": "string", "minLength": 1 },
          "memory": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "publications": {
    "http": {
      "contract": "http-endpoint",
      "material": {
        "url": "$outputs.url",
        "internalHost": "$outputs.internalHost",
        "internalPort": "$outputs.internalPort"
      }
    }
  },
  "acceptedProjectionFamilies": ["env", "secret-env"],
  "outputs": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "meaning": "Provider-local upstream URL (scheme-bearing) used by gateway/listener components."
    },
    {
      "name": "internalHost",
      "type": "string",
      "required": true,
      "meaning": "Provider-local service host."
    },
    {
      "name": "internalPort",
      "type": "integer",
      "required": true,
      "meaning": "Provider-local service port."
    }
  ],
  "capabilityTerms": [
    "always-on",
    "scale-to-zero",
    "websocket",
    "long-request",
    "sticky-session",
    "geo-routing",
    "crons",
    "private-networking"
  ]
}
