{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/custom-domain",
  "@type": "ComponentKind",
  "name": "custom-domain",
  "version": "v1",
  "aliases": ["custom-domain"],
  "description": "DNS + TLS-terminated public domain pointing at a target URL. Listens on a sibling worker namespace to obtain its allocated URL, then publishes its FQDN to the sibling namespace path.",
  "x-ts": {
    "fileBasename": "custom-domain",
    "prefix": "CustomDomain",
    "shapeId": "custom-domain"
  },
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name"],
    "additionalProperties": true,
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Fully-qualified domain name (e.g. `notes.example.com`)."
      }
    }
  },
  "publishes": [
    {
      "namespacePath": "<app-id>.<component-name>",
      "material": {
        "fqdn": "$outputs.fqdn",
        "certificateId": "$outputs.certificateId"
      }
    }
  ],
  "listens": {
    "<sibling-worker-namespace>": {
      "shape": "target",
      "envMap": {
        "DESCRIPTION": "Reads the `url` field from the listened worker material to determine the upstream target. AppSpec listen options declare `as: target`."
      }
    }
  },
  "outputs": [
    {
      "name": "fqdn",
      "type": "string",
      "required": true,
      "meaning": "Resolved fully-qualified domain name."
    },
    {
      "name": "certificateId",
      "type": "string",
      "required": false,
      "meaning": "Provider-scope TLS certificate identifier."
    },
    {
      "name": "nameservers",
      "type": "string[]",
      "required": false,
      "meaning": "DNS nameserver list (when delegated)."
    }
  ],
  "capabilities": [
    "wildcard",
    "auto-tls",
    "sni",
    "http3",
    "alpn-acme",
    "redirects"
  ]
}
