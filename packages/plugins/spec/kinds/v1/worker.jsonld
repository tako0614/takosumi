{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/worker",
  "@type": "ComponentKind",
  "name": "worker",
  "version": "v1",
  "referenceAliases": ["worker"],
  "description": "Serverless JS function whose entrypoint is read from the resolved source view.",
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["entrypoint"],
    "additionalProperties": true,
    "properties": {
      "entrypoint": {
        "type": "string",
        "minLength": 1,
        "description": "Source-root-relative worker module path inside the resolved source view."
      },
      "env": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Optional env vars / bindings."
      }
    }
  },
  "publications": {
    "http": {
      "contract": "http-endpoint",
      "exampleMaterialMapping": {
        "targets": [
          {
            "name": "default",
            "url": "$outputs.url",
            "visibility": "private"
          }
        ]
      }
    }
  },
  "listens": {
    "*": {
      "accepts": [
        "service-binding",
        "object-store",
        "event-channel",
        "identity.oidc@v1",
        "billing.port@v1"
      ],
      "projectionFamilies": ["secret-env", "config-mount"]
    }
  },
  "outputs": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "meaning": "Provider-local upstream URL (scheme-bearing) used by gateway/listener components."
    },
    {
      "name": "id",
      "type": "string",
      "required": true,
      "meaning": "Provider-scope worker identifier."
    },
    {
      "name": "version",
      "type": "string",
      "required": false,
      "meaning": "Current deployed worker version."
    }
  ],
  "capabilityTerms": [
    "scale-to-zero",
    "long-request",
    "geo-routing"
  ]
}
