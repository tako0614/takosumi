{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/worker",
  "@type": "ComponentKind",
  "name": "worker",
  "version": "v1",
  "aliases": ["worker"],
  "description": "Serverless JS function backed by an uploaded `js-bundle` artifact descriptor.",
  "x-ts": {
    "fileBasename": "worker",
    "prefix": "Worker",
    "shapeId": "worker"
  },
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["artifact", "compatibilityDate"],
    "additionalProperties": true,
    "properties": {
      "artifact": {
        "description": "Resolved uploaded artifact descriptor. `kind` must be `js-bundle` and `hash` is required.",
        "x-ts-type": {
          "import": "takosumi-contract",
          "name": "Artifact"
        }
      },
      "compatibilityDate": {
        "type": "string",
        "minLength": 1,
        "description": "Cloudflare Workers compatibility date (e.g. `2025-01-01`)."
      },
      "compatibilityFlags": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "description": "Optional compatibility flags (e.g. `nodejs_compat`)."
      },
      "env": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Optional env vars / bindings."
      }
    }
  },
  "publishes": [
    {
      "namespacePath": "<app-id>.<component-name>",
      "material": {
        "url": "$outputs.url",
        "id": "$outputs.id"
      }
    }
  ],
  "listens": {
    "<sibling-namespace-path>": {
      "shape": "env",
      "envMap": {
        "DESCRIPTION": "Accepts any sibling namespace material; AppSpec listen options declare `as: env` with optional `prefix:` to expand each material field into `${PREFIX}_*` env vars."
      }
    }
  },
  "outputs": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "meaning": "Allocated public URL (scheme-bearing)."
    },
    {
      "name": "id",
      "type": "string",
      "required": true,
      "meaning": "Provider-scope worker identifier."
    },
    {
      "name": "version",
      "type": "string",
      "required": false,
      "meaning": "Current deployed bundle version."
    }
  ],
  "capabilities": [
    "scale-to-zero",
    "long-request",
    "geo-routing"
  ]
}
