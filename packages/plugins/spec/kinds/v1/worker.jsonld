{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/worker",
  "@type": "ComponentKind",
  "name": "worker",
  "version": "v1",
  "aliases": ["worker"],
  "description": "Serverless JS function whose entrypoint is read from the prepared source snapshot.",
  "x-ts": {
    "fileBasename": "worker",
    "prefix": "Worker"
  },
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["entrypoint"],
    "additionalProperties": true,
    "properties": {
      "entrypoint": {
        "type": "string",
        "minLength": 1,
        "description": "Source-root-relative worker module path inside the prepared source snapshot."
      },
      "compatibilityDate": {
        "type": "string",
        "minLength": 1,
        "description": "Optional provider compatibility date for runtimes that use one (for example Cloudflare Workers)."
      },
      "compatibilityFlags": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "description": "Optional compatibility flags (e.g. `nodejs_compat`)."
      },
      "env": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Optional env vars / bindings."
      }
    }
  },
  "publications": {
    "http": {
      "contract": "http-endpoint",
      "material": {
        "url": "$outputs.url",
        "id": "$outputs.id"
      }
    }
  },
  "listens": {
    "binding": {
      "shape": "env",
      "envMap": {
        "DESCRIPTION": "Accepts any listened material; AppSpec listen options declare `from`, `as: env`, and optional `prefix:` to expand each material field into `${PREFIX}_*` env vars."
      }
    }
  },
  "outputs": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "meaning": "Allocated public URL (scheme-bearing)."
    },
    {
      "name": "id",
      "type": "string",
      "required": true,
      "meaning": "Provider-scope worker identifier."
    },
    {
      "name": "version",
      "type": "string",
      "required": false,
      "meaning": "Current deployed worker version."
    }
  ],
  "capabilities": [
    "scale-to-zero",
    "long-request",
    "geo-routing"
  ]
}
