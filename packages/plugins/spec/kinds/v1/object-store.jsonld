{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/object-store",
  "@type": "ComponentKind",
  "name": "object-store",
  "version": "v1",
  "referenceAliases": ["object-store"],
  "description": "Bucket-style object storage intended to be bindable across compatible S3-class providers. Publishes endpoint + credential refs as a local publication.",
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name"],
    "additionalProperties": true,
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Logical bucket name (provider applies its own scoping rules)."
      },
      "public": {
        "type": "boolean",
        "description": "Request anonymous-read policy when true. Operator policy and the selected implementation materialize or reject the request."
      },
      "versioning": {
        "type": "boolean",
        "description": "Request object versioning. Operator policy and the selected implementation materialize or reject the request."
      },
      "region": {
        "type": "string",
        "minLength": 1,
        "description": "Provider region (when applicable)."
      }
    }
  },
  "publications": {
    "bucket": {
      "contract": "object-store",
      "exampleMaterialMapping": {
        "bucket": "$outputs.bucket",
        "endpoint": "$outputs.endpoint",
        "region": "$outputs.region",
        "accessKeyIdRef": "$outputs.accessKeyRef",
        "secretAccessKeyRef": "$outputs.secretKeyRef"
      }
    }
  },
  "outputs": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "meaning": "Provider-scope bucket name."
    },
    {
      "name": "endpoint",
      "type": "string",
      "required": true,
      "meaning": "S3-class endpoint URL."
    },
    {
      "name": "region",
      "type": "string",
      "required": true,
      "meaning": "Bucket region."
    },
    {
      "name": "accessKeyRef",
      "type": "string",
      "required": true,
      "meaning": "Reference to secret store entry holding access key id."
    },
    {
      "name": "secretKeyRef",
      "type": "string",
      "required": true,
      "meaning": "Reference to secret store entry holding secret access key."
    }
  ],
  "capabilityTerms": [
    "versioning",
    "presigned-urls",
    "server-side-encryption",
    "public-access",
    "event-notifications",
    "lifecycle-rules",
    "multipart-upload"
  ]
}
