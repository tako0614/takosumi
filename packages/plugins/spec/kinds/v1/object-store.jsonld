{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/object-store",
  "@type": "ComponentKind",
  "name": "object-store",
  "version": "v1",
  "aliases": ["object-store"],
  "description": "Bucket-style object storage. Provider-portable across S3-class APIs. Publishes endpoint + credential refs to the sibling namespace path.",
  "x-ts": {
    "fileBasename": "object-store",
    "prefix": "ObjectStore",
    "shapeId": "object-store"
  },
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name"],
    "additionalProperties": true,
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Logical bucket name (provider applies its own scoping rules)."
      },
      "public": {
        "type": "boolean",
        "description": "Allow anonymous reads when true."
      },
      "versioning": {
        "type": "boolean",
        "description": "Enable object versioning when supported."
      },
      "region": {
        "type": "string",
        "minLength": 1,
        "description": "Provider region (when applicable)."
      }
    }
  },
  "publishes": [
    {
      "namespacePath": "<app-id>.<component-name>",
      "material": {
        "bucket": "$outputs.bucket",
        "endpoint": "$outputs.endpoint",
        "region": "$outputs.region",
        "accessKeyRef": "$outputs.accessKeyRef",
        "secretKeyRef": "$outputs.secretKeyRef"
      }
    }
  ],
  "listens": {},
  "outputs": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "meaning": "Provider-scope bucket name."
    },
    {
      "name": "endpoint",
      "type": "string",
      "required": true,
      "meaning": "S3-class endpoint URL."
    },
    {
      "name": "region",
      "type": "string",
      "required": true,
      "meaning": "Bucket region."
    },
    {
      "name": "accessKeyRef",
      "type": "string",
      "required": true,
      "meaning": "Reference to secret store entry holding access key id."
    },
    {
      "name": "secretKeyRef",
      "type": "string",
      "required": true,
      "meaning": "Reference to secret store entry holding secret access key."
    }
  ],
  "capabilities": [
    "versioning",
    "presigned-urls",
    "server-side-encryption",
    "public-access",
    "event-notifications",
    "lifecycle-rules",
    "multipart-upload"
  ]
}
