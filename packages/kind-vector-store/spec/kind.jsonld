{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/vector-store",
  "@type": "ComponentKind",
  "name": "vector-store",
  "version": "v1",
  "referenceAliases": ["vector-store"],
  "description": "Vector index for embeddings, similarity search, and vector metadata operations.",
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name", "dimensions", "metric"],
    "additionalProperties": false,
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Index name."
      },
      "dimensions": {
        "type": "integer",
        "minimum": 1,
        "description": "Vector dimensions."
      },
      "metric": {
        "type": "string",
        "enum": ["cosine", "euclidean", "dot-product"],
        "description": "Distance metric."
      }
    }
  },
  "outputSlots": {
    "index": {
      "contract": "service-binding",
      "exampleMaterialMapping": {
        "service": "$outputs.indexId",
        "protocol": "vector",
        "connectionUrl": "$outputs.url",
        "tokenRef": { "secretRef": "$outputs.tokenSecretRef" }
      }
    }
  },
  "outputs": [
    {
      "name": "indexId",
      "type": "string",
      "required": true,
      "meaning": "Implementation-scoped index identifier."
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "meaning": "Index name."
    },
    {
      "name": "url",
      "type": "string",
      "required": false,
      "meaning": "Index endpoint URL if available."
    },
    {
      "name": "tokenSecretRef",
      "type": "string",
      "required": false,
      "meaning": "Secret reference for clients that need token-based access."
    }
  ],
  "capabilityTerms": [
    "vector-upsert",
    "vector-query",
    "vector-delete"
  ]
}
