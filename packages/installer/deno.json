{
  "name": "@takos/takosumi-installer",
  "version": "0.1.0",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./yaml-parser": "./src/yaml-parser.ts",
    "./git-fetch": "./src/git-fetch.ts",
    "./deploy-client": "./src/deploy-client.ts"
  },
  "tasks": {
    "check": "bash -lc 'find src -name \"*.ts\" ! -name \"*_test.ts\" -print0 | xargs -0 deno check'",
    "test": "deno test --allow-all"
  },
  "imports": {
    "@takos/takosumi-contract": "jsr:@takos/takosumi-contract@^2.6.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.5"
  }
}
