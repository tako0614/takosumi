{
  "name": "@takos/takosumi-kernel",
  "version": "0.14.0",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./adapters": "./src/adapters/mod.ts",
    "./agents": "./src/agents/mod.ts",
    "./api": "./src/api/mod.ts",
    "./app_context": "./src/app_context.ts",
    "./bootstrap": "./src/bootstrap.ts",
    "./plugins": "./src/plugins/mod.ts",
    "./server": "./src/index.ts"
  },
  "imports": {
    "takosumi-contract": "jsr:@takos/takosumi-contract@^2.6.0",
    "takosumi-installer": "jsr:@takos/takosumi-installer@^0.1.0",
    "takosumi-contract/app-spec": "jsr:@takos/takosumi-contract@^2.6.0/app-spec",
    "takosumi-contract/installer-api": "jsr:@takos/takosumi-contract@^2.6.0/installer-api",
    "takosumi-contract/type-catalog": "jsr:@takos/takosumi-contract@^2.6.0/type-catalog",
    "takosumi-contract/reference/plugin": "jsr:@takos/takosumi-contract@^2.6.0/reference/plugin",
    "takosumi-contract/reference/plugin-sdk": "jsr:@takos/takosumi-contract@^2.6.0/reference/plugin-sdk",
    "takosumi-contract/reference/provider-plugin": "jsr:@takos/takosumi-contract@^2.6.0/reference/provider-plugin",
    "takosumi-contract/reference/kernel-plugin-adapter": "jsr:@takos/takosumi-contract@^2.6.0/reference/kernel-plugin-adapter",
    "takosumi-contract/reference/runtime-agent": "jsr:@takos/takosumi-contract@^2.6.0/reference/runtime-agent",
    "takosumi-contract/reference/runtime-agent-lifecycle": "jsr:@takos/takosumi-contract@^2.6.0/reference/runtime-agent-lifecycle",
    "takosumi-contract/internal/api": "jsr:@takos/takosumi-contract@^2.6.0/internal/api",
    "takosumi-contract/internal/rpc": "jsr:@takos/takosumi-contract@^2.6.0/internal/rpc",
    "takosumi-contract/reference/error-category": "jsr:@takos/takosumi-contract@^2.6.0/reference/error-category",
    "takosumi-contract/reference/shape": "jsr:@takos/takosumi-contract@^2.6.0/reference/shape",
    "takosumi-contract/reference/types": "jsr:@takos/takosumi-contract@^2.6.0/reference/types"
  },
  "tasks": {
    "check": "bash -lc 'find src -name \"*.ts\" ! -name \"*_test.ts\" -print0 | xargs -0 deno check'",
    "start": "deno run --allow-net --allow-env --allow-read --allow-write src/index.ts",
    "test": "deno test --allow-all",
    "db:migrate": "deno run --allow-env --allow-read --allow-net scripts/db-migrate.ts",
    "db:migrate:dry-run": "deno run --allow-env --allow-read scripts/db-migrate.ts --dry-run",
    "db:migrate:down": "deno run --allow-env --allow-read --allow-net scripts/db-migrate-down.ts",
    "bootstrap:initial": "deno run --allow-env --allow-read --allow-net --allow-write scripts/bootstrap-initial.ts"
  }
}
