{
  "@context": "https://takosumi.com/contexts/deploy.jsonld",
  "@id": "https://takosumi.com/descriptors/authoring/composite-expansion/v1",
  "@type": "takos:AuthoringExpansionDescriptor",
  "shortRef": "authoring.composite-expansion@v1",
  "domain": "authoring",
  "lifecycleDomain": "shape-derivation",
  "changeEffect": "shape-derivation",
  "description": "Authoring expansion that replaces a composite.* compute reference with its canonical runtime + resource (+ optional output + route) contract instances before plan finalises.",
  "expandsTo": [
    "takosumi.com/v1 App",
    "takosumi.com/v1 Environment"
  ],
  "invariants": [
    "expansion-before-plan",
    "descriptor-digest-pinned",
    "no-runtime-or-provider-semantics"
  ]
}
