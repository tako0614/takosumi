{
  "@context": "https://takosumi.com/contexts/deploy.jsonld",
  "@id": "https://takosumi.com/contracts/composite/web-app-with-cdn/v1",
  "@type": "CompositeContractDescriptor",
  "shortRef": "composite.web-app-with-cdn@v1",
  "domain": "composite",
  "lifecycleDomain": "revisioned-runtime",
  "changeEffect": "app-release",
  "description": "Web app fronted by a CDN with an asset object-store bucket. Expands into a runtime.js-worker@v1 component plus a resource.object-store.s3@v1 (binding env ASSETS_BUCKET) plus a output.http-endpoint@v1 + interface.http@v1 route. The CDN edge tier (output.http-endpoint@v1 + interface.http@v1) is marked optional so a CDN-tier provider outage degrades — never escalates to outage — while the origin runtime + asset bucket stay critical-path.",
  "expandsTo": [
    {
      "ref": "runtime.js-worker@v1",
      "optional": false
    },
    {
      "ref": "resource.object-store.s3@v1",
      "optional": false
    },
    {
      "ref": "output.http-endpoint@v1",
      "optional": true
    },
    {
      "ref": "interface.http@v1",
      "optional": true
    }
  ],
  "invariants": [
    "expansion-before-plan",
    "descriptor-digest-pinned",
    "no-provider-semantics",
    "optional-providers-degrade-only"
  ]
}
