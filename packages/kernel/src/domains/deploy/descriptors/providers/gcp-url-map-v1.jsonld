{
  "@context": "https://takos.dev/contexts/deploy.jsonld",
  "@id": "https://takos.dev/providers/gcp/url-map/v1",
  "@type": "ProviderCapabilityDescriptor",
  "shortRef": "provider.gcp.url-map@v1",
  "materializationProfiles": [
    {
      "ref": "materialize.gcp-url-map@v1",
      "contracts": {
        "runtime": "runtime.oci-container@v1",
        "interfaces": [
          "interface.http@v1"
        ]
      },
      "roles": [
        "router"
      ],
      "runtimeCapabilities": [
        "host-and-path-based-routing"
      ],
      "limitations": [
        "host-rule-cap-per-url-map",
        "regional-or-global-url-map-boundary"
      ]
    }
  ],
  "providerNativeSchemas": [
    "google.compute.url-map@v1",
    "google.compute.path-matcher@v1"
  ],
  "sourceDocs": [
    "https://cloud.google.com/load-balancing/docs/url-map-concepts",
    "https://cloud.google.com/compute/docs/reference/rest/v1/urlMaps"
  ]
}
