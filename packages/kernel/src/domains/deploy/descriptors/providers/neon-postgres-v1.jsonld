{
  "@context": "https://takosumi.com/contexts/deploy.jsonld",
  "@id": "https://takosumi.com/providers/neon/postgres/v1",
  "@type": "ProviderCapabilityDescriptor",
  "shortRef": "provider.neon.postgres@v1",
  "resourceContracts": [
    {
      "contract": "resource.sql.postgres@v1",
      "accessModes": [
        "database-url",
        "migration-admin"
      ],
      "restoreModes": [
        "backup-to-new-instance",
        "pitr-to-new-instance"
      ],
      "limitations": [
