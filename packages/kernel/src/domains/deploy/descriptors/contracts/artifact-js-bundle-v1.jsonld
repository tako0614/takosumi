  "@type": "ArtifactContractDescriptor",
  "shortRef": "artifact.js-bundle@v1",
  "domain": "artifact",
  "lifecycleDomain": "revisioned-runtime",
  "changeEffect": "app-release",
  "configSchema": {
    "type": "object",
    "properties": {
      "bundleFormat": {
        "enum": [
          "esm"
        ]
      },
      "entrypoint": {
