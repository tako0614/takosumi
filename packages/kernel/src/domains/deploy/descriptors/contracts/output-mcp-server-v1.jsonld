{
  "@context": "https://takosumi.com/contexts/deploy.jsonld",
  "@id": "https://takosumi.com/contracts/output/mcp-server/v1",
  "@type": "OutputContractDescriptor",
  "shortRef": "output.mcp-server@v1",
  "domain": "output",
  "lifecycleDomain": "declaration-output",
  "changeEffect": "output-binding",
  "outputs": {
    "url": {
      "valueType": "url",
      "sensitivity": "internal",
      "allowedInjections": [
        "env",
        "service-binding"
      ],
      "defaultInjectable": false
    },
    "auth": {
      "valueType": "secret-ref",
      "sensitivity": "credential",
      "allowedInjections": [
        "secret-ref"
      ],
      "defaultInjectable": false
    }
  }
}
