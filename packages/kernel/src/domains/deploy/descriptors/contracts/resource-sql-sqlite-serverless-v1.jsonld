{
  "@context": "https://takos.dev/contexts/deploy.jsonld",
  "@id": "https://takos.dev/contracts/resource/sql/sqlite-serverless/v1",
  "@type": "ResourceContractDescriptor",
  "shortRef": "resource.sql.sqlite-serverless@v1",
  "domain": "resource",
  "lifecycleDomain": "durable-state",
  "changeEffect": "resource-instance",
  "accessModes": [
    "sql-runtime-binding",
    "sql-query-api",
    "migration-admin"
  ],
  "permissions": [
    "sql:read",
    "sql:write",
    "sql:ddl"
  ],
  "schemaModel": "sql",
  "migrationEngines": [
    "sqlite@3",
    "takos-sqlite@v1"
  ]
}
