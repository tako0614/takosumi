{
  "@context": "https://takosumi.com/reference/kernel/contexts/deploy.jsonld",
  "@id": "https://takosumi.com/reference/kernel/contracts/resource/sql/postgres/v1",
  "@type": "ResourceContractDescriptor",
  "shortRef": "resource.sql.postgres@v1",
  "domain": "resource",
  "lifecycleDomain": "durable-state",
  "changeEffect": "resource-instance",
  "accessModes": [
    "database-url",
    "migration-admin",
    "sql-query-api"
  ],
  "permissions": [
    "sql:read",
    "sql:write",
    "sql:ddl"
  ],
  "schemaModel": "sql",
  "migrationEngines": [
    "postgres@16"
  ]
}
