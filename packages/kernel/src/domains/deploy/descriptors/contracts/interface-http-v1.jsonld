{
  "@context": "https://takosumi.com/contexts/deploy.jsonld",
  "@id": "https://takosumi.com/contracts/interface/http/v1",
  "@type": "InterfaceContractDescriptor",
  "shortRef": "interface.http@v1",
  "domain": "interface",
  "lifecycleDomain": "revisioned-runtime",
  "changeEffect": "network-config",
  "exposureEligible": true,
  "assignmentGranularity": [
    "request"
  ],
  "weightedAssignment": true,
