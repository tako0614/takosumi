{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "metadata": {
    "name": "takos-selfhost-live-smoke",
    "spaceId": "space_live_smoke",
    "groupId": "group_live_smoke",
    "activationId": "activation_selfhost_live_smoke",
    "runId": "selfhost-live-provisioning-smoke",
    "materializedAt": "2026-05-01T00:00:00.000Z"
  },
  "resources": [
    {
      "shape": "object-store@v1",
      "name": "data",
      "provider": "filesystem",
      "spec": {
        "name": "takos-live-smoke-vm-data"
      }
    },
    {
      "shape": "postgres@v1",
      "name": "db",
      "provider": "local-docker",
      "spec": {
        "version": "16",
        "size": "small"
      }
    },
    {
      "shape": "web-service@v1",
      "name": "api",
      "provider": "systemd-unit",
      "spec": {
        "image": "/usr/local/bin/takos-live-smoke",
        "port": 8080,
        "scale": { "min": 1, "max": 1 },
        "command": ["/usr/local/bin/takos-live-smoke", "--port", "8080"],
        "bindings": {
          "DATABASE_URL": "${ref:db.connectionString}"
        }
      }
    },
    {
      "shape": "gateway@v1",
      "name": "primary",
      "provider": "coredns-local",
      "spec": {
        "listeners": {
          "public": {
            "protocol": "https",
            "host": "selfhost-live-smoke.example.test",
            "tls": "auto"
          }
        },
        "routes": [{ "listener": "public", "path": "/", "to": "upstream" }],
        "target": "${ref:api.url}"
      }
    }
  ]
}
