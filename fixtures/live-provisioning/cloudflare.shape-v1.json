{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "metadata": {
    "name": "takos-cloudflare-live-smoke",
    "spaceId": "space_live_smoke",
    "groupId": "group_live_smoke",
    "activationId": "activation_cloudflare_live_smoke",
    "runId": "cloudflare-live-provisioning-smoke",
    "materializedAt": "2026-04-30T00:00:00.000Z"
  },
  "resources": [
    {
      "shape": "object-store@v1",
      "name": "assets",
      "provider": "cloudflare-r2",
      "spec": {
        "name": "takos-cloudflare-live-smoke-assets",
        "public": false
      }
    },
    {
      "shape": "web-service@v1",
      "name": "worker",
      "provider": "cloudflare-container",
      "spec": {
        "image": "ghcr.io/takos/live-smoke:latest",
        "port": 8080,
        "scale": { "min": 0, "max": 50 },
        "bindings": {
          "ASSETS_BUCKET": "${ref:assets.bucket}",
          "ASSETS_ENDPOINT": "${ref:assets.endpoint}"
        }
      }
    },
    {
      "shape": "custom-domain@v1",
      "name": "primary",
      "provider": "cloudflare-dns",
      "spec": {
        "name": "cloudflare-live-smoke.example.test",
        "target": "${ref:worker.url}",
        "certificate": { "kind": "auto" }
      }
    }
  ]
}
