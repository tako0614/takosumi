{
  "apiVersion": "takos.dev/hosting/v1",
  "kind": "TakosDistribution",
  "metadata": {
    "name": "takos-kubernetes-live-smoke",
    "spaceId": "space_live_smoke",
    "groupId": "group_live_smoke",
    "activationId": "activation_kubernetes_live_smoke",
    "runId": "kubernetes-live-provisioning-smoke",
    "materializedAt": "2026-04-30T00:00:00.000Z"
  },
  "resources": [
    {
      "shape": "web-service@v1",
      "name": "web",
      "provider": "k3s-deployment",
      "spec": {
        "image": "ghcr.io/takos/live-smoke:latest",
        "port": 8080,
        "scale": { "min": 1, "max": 3 },
        "env": { "SMOKE": "true" },
        "resources": { "cpu": "200m", "memory": "256Mi" }
      }
    },
    {
      "shape": "custom-domain@v1",
      "name": "primary",
      "provider": "coredns-local",
      "spec": {
        "name": "kubernetes-live-smoke.example.test",
        "target": "${ref:web.url}"
      }
    }
  ]
}
