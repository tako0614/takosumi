{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "metadata": {
    "name": "takos-azure-live-smoke",
    "spaceId": "space_live_smoke",
    "groupId": "group_live_smoke",
    "activationId": "activation_azure_live_smoke",
    "runId": "azure-live-provisioning-smoke",
    "materializedAt": "2026-05-02T00:00:00.000Z",
    "comment": "Azure shape-providers are not yet curated; this fixture documents the intent. Operators should pick a runtime/edge equivalent (e.g. cloud-run + cloudflare-dns or aws-fargate + route53) until takosumi ships an Azure shape-provider set."
  },
  "resources": [
    {
      "shape": "web-service@v1",
      "name": "web",
      "provider": "aws-fargate",
      "spec": {
        "image": "ghcr.io/takos/live-smoke:latest",
        "port": 8080,
        "scale": { "min": 1, "max": 3 }
      }
    },
    {
      "shape": "custom-domain@v1",
      "name": "primary",
      "provider": "route53",
      "spec": {
        "name": "azure-live-smoke.example.test",
        "target": "${ref:web.url}",
        "certificate": { "kind": "auto" }
      }
    }
  ]
}
