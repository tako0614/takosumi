{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "metadata": {
    "name": "takos-selfhosted-vm-live-smoke",
    "spaceId": "space_live_smoke",
    "groupId": "group_live_smoke",
    "activationId": "activation_selfhosted_vm_live_smoke",
    "runId": "selfhosted-vm-live-provisioning-smoke",
    "materializedAt": "2026-05-01T00:00:00.000Z"
  },
  "resources": [
    {
      "shape": "object-store@v1",
      "name": "data",
      "provider": "filesystem",
      "spec": {
        "name": "takos-live-smoke-vm-data"
      }
    },
    {
      "shape": "database-postgres@v1",
      "name": "db",
      "provider": "local-docker",
      "spec": {
        "version": "16",
        "size": "small"
      }
    },
    {
      "shape": "web-service@v1",
      "name": "api",
      "provider": "systemd-unit",
      "spec": {
        "image": "/usr/local/bin/takos-live-smoke",
        "port": 8080,
        "scale": { "min": 1, "max": 1 },
        "command": ["/usr/local/bin/takos-live-smoke", "--port", "8080"],
        "bindings": {
          "DATABASE_URL": "${ref:db.connectionString}"
        }
      }
    },
    {
      "shape": "custom-domain@v1",
      "name": "primary",
      "provider": "coredns-local",
      "spec": {
        "name": "selfhosted-vm-live-smoke.example.test",
        "target": "${ref:api.url}"
      }
    }
  ]
}
