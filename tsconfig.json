{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "types": ["bun", "node"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@takosjp/takosumi/contract/deploy-control-api": [
        "./packages/schema/src/deploy-control-api.ts"
      ],
      "@takosjp/takosumi-accounts-contract": [
        "./packages/accounts-contract/src/mod.ts"
      ],
      "@takosjp/takosumi-accounts-service": [
        "./packages/accounts-service/src/mod.ts"
      ],
      "@takosjp/takosumi-accounts-cli": ["./packages/cli/src/main.ts"],
      "@takosjp/takosumi-platform-services": [
        "./packages/platform-services/src/mod.ts"
      ],
      "takosumi-contract": ["./packages/schema/src/index.ts"],
      "takosumi-contract/deploy-control-api": ["./packages/schema/src/deploy-control-api.ts"],
      "takosumi-contract/sources": ["./packages/schema/src/sources.ts"],
      "takosumi-contract/provider-env-rules": ["./packages/schema/src/provider-env-rules.ts"],
      "takosumi-contract/reference/compat": [
        "./packages/schema/src/reference-compat.ts"
      ],
      "takosumi-contract/reference/catalog": ["./packages/schema/src/catalog.ts"],
      "takosumi-contract/reference/implementation": ["./packages/schema/src/implementation.ts"],
      "takosumi-contract/reference/runtime-agent": [
        "./packages/schema/src/runtime-agent.ts"
      ],
      "takosumi-contract/reference/runtime-agent-lifecycle": [
        "./packages/schema/src/runtime-agent-lifecycle.ts"
      ],
      "takosumi-contract/reference/runtime-capability": [
        "./packages/schema/src/runtime-capability.ts"
      ],
      "takosumi-contract/reference/host-blocklist": [
        "./packages/schema/src/reference/host-blocklist.ts"
      ],
      "takosumi-contract/reference/ip-classification": [
        "./packages/schema/src/reference/ip-classification.ts"
      ],
      "takosumi-contract/reference/prepared-source-core": [
        "./packages/schema/src/reference/prepared-source-core.ts"
      ],
      "takosumi-contract/reference/types": ["./packages/schema/src/types.ts"],
      "takosumi-contract/internal/api": ["./packages/schema/src/internal-api.ts"],
      "takosumi-contract/internal/provider-adapter": [
        "./packages/schema/src/provider-adapter.ts"
      ],
      "takosumi-contract/internal/rpc": ["./packages/schema/src/internal-rpc.ts"],
      "takosumi-contract/internal/crypto": ["./packages/schema/src/internal-crypto.ts"],
      "takosumi-contract/spaces": ["./packages/schema/src/spaces.ts"],
      "takosumi-contract/installations": ["./packages/schema/src/installations.ts"],
      "takosumi-contract/capability-bindings": ["./packages/schema/src/capability-bindings.ts"],
      "takosumi-contract/dependencies": ["./packages/schema/src/dependencies.ts"],
      "takosumi-contract/activity": ["./packages/schema/src/activity.ts"],
      "takosumi-contract/output-snapshots": ["./packages/schema/src/output-snapshots.ts"],
      "takosumi-contract/runs": ["./packages/schema/src/runs.ts"],
      "takosumi-contract/deployments": ["./packages/schema/src/deployments.ts"],
      "takosumi-contract/install-link": ["./packages/schema/src/install-link.ts"],
      "takosumi-contract/backups": ["./packages/schema/src/backups.ts"],
      "takosumi-rootgen": ["./packages/rootgen/src/mod.ts"],
      "takosumi-graph": ["./packages/graph/src/mod.ts"],
      "takosumi-policy": ["./packages/policy/src/mod.ts"],

      "takosumi-runtime-agent/prepared-source-reader": [
        "./src/runtime-agent/prepared_source_reader.ts"
      ]
    }
  },
  "include": [
    "src",
    "opentofu-modules",
    "packages/schema",
    "packages/rootgen",
    "packages/graph",
    "packages/accounts-contract",
    "packages/accounts-service",
    "packages/cli",
    "packages/platform-services",
    "deploy/accounts-cloudflare",
    "deploy/node-postgres",
    "shims"
  ],
  "exclude": [
    "**/*_test.ts",
    "src/cli/tests",
    "src/service/scripts"
  ]
}
