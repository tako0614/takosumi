      "takosumi-deploy-control": ["./src/deploy-control/mod.ts"],
      "takosumi-deploy-control/git-fetch": ["./src/deploy-control/git-fetch.ts"],
      "takosumi-deploy-control/deploy-client": ["./src/deploy-control/deploy-client.ts"],
      "takosumi-runtime-agent/prepared-source-reader": [
        "./src/runtime-agent/prepared_source_reader.ts"
      ]
    }
  },
  "include": [
    "src",
    "packages/accounts-contract",
    "packages/accounts-service",
    "packages/cli",
    "packages/all",
    "packages/platform-services",
    "deploy/accounts-cloudflare",
    "deploy/node-postgres",
    "shims"
  ],
  "exclude": [
    "**/*_test.ts",
    "packages/dashboard-ui",
    "src/cli/tests",
    "src/service/scripts"
  ]
