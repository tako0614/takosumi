{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "types": ["bun", "node"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@takosjp/takosumi/contract/deploy-control-api": [
        "./src/contract/deploy-control-api.ts"
      ],
      "@takosjp/takosumi-accounts-contract": [
        "./packages/accounts-contract/src/mod.ts"
      ],
      "@takosjp/takosumi-accounts-service": [
        "./packages/accounts-service/src/mod.ts"
      ],
      "@takosjp/takosumi-accounts-cli": ["./packages/cli/src/main.ts"],
      "@takosjp/takosumi-platform-services": [
        "./packages/platform-services/src/mod.ts"
      ],
      "takosumi-contract": ["./src/contract/index.ts"],
      "takosumi-contract/deploy-control-api": ["./src/contract/deploy-control-api.ts"],
      "takosumi-contract/provider-env-rules": ["./src/contract/provider-env-rules.ts"],
      "takosumi-contract/reference/compat": [
        "./src/contract/reference-compat.ts"
      ],
      "takosumi-contract/reference/catalog": ["./src/contract/catalog.ts"],
      "takosumi-contract/reference/implementation": ["./src/contract/implementation.ts"],
      "takosumi-contract/reference/runtime-agent": [
        "./src/contract/runtime-agent.ts"
      ],
      "takosumi-contract/reference/runtime-agent-lifecycle": [
        "./src/contract/runtime-agent-lifecycle.ts"
      ],
      "takosumi-contract/reference/runtime-capability": [
        "./src/contract/runtime-capability.ts"
      ],
      "takosumi-contract/reference/host-blocklist": [
        "./src/contract/reference/host-blocklist.ts"
      ],
      "takosumi-contract/reference/ip-classification": [
        "./src/contract/reference/ip-classification.ts"
      ],
      "takosumi-contract/reference/prepared-source-core": [
        "./src/contract/reference/prepared-source-core.ts"
      ],
      "takosumi-contract/reference/types": ["./src/contract/types.ts"],
      "takosumi-contract/internal/api": ["./src/contract/internal-api.ts"],
      "takosumi-contract/internal/provider-adapter": [
        "./src/contract/provider-adapter.ts"
      ],
      "takosumi-contract/internal/rpc": ["./src/contract/internal-rpc.ts"],

      "takosumi-runtime-agent/prepared-source-reader": [
        "./src/runtime-agent/prepared_source_reader.ts"
      ]
    }
  },
  "include": [
    "src",
    "templates",
    "packages/accounts-contract",
    "packages/accounts-service",
    "packages/cli",
    "packages/platform-services",
    "deploy/accounts-cloudflare",
    "deploy/node-postgres",
    "shims"
  ],
  "exclude": [
    "**/*_test.ts",
    "src/cli/tests",
    "src/service/scripts"
  ]
}
