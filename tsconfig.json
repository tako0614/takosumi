{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "types": ["bun", "node", "deno"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@std/assert": ["./shims/std/assert.ts"],
      "@std/fmt/colors": ["./shims/std/colors.ts"],
      "@std/testing/mock": ["./shims/std/mock.ts"],
      "@std/yaml": ["./shims/std/yaml.ts"],
      "@std/path": ["./shims/std/path.ts"],
      "@std/path/*": ["./shims/std/path.ts"],
      "@std/fs/walk": ["./shims/std/fs.ts"],
      "@std/fs": ["./shims/std/fs.ts"],

      "jsr:@std/assert": ["./shims/std/assert.ts"],
      "jsr:@std/assert@*": ["./shims/std/assert.ts"],
      "jsr:@std/assert@^1.0.0": ["./shims/std/assert.ts"],
      "jsr:@std/assert@^1.0.5": ["./shims/std/assert.ts"],
      "jsr:@std/assert@^1.0.6": ["./shims/std/assert.ts"],
      "jsr:@std/yaml": ["./shims/std/yaml.ts"],
      "jsr:@std/yaml@*": ["./shims/std/yaml.ts"],
      "jsr:@std/yaml@^1.0.0": ["./shims/std/yaml.ts"],
      "jsr:@std/yaml@^1.0.5": ["./shims/std/yaml.ts"],
      "jsr:@std/path@*": ["./shims/std/path.ts"],
      "jsr:@std/path@^1.0.6": ["./shims/std/path.ts"],
      "jsr:@std/fs@*": ["./shims/std/fs.ts"],
      "jsr:@std/fs@^1.0.5/walk": ["./shims/std/fs.ts"],

      "@takos/takosumi-contract": ["./src/contract/mod.ts"],
      "@takos/takosumi-contract/app-spec": ["./src/contract/app-spec.ts"],
      "@takos/takosumi-contract/catalog": ["./src/contract/catalog.ts"],
      "@takos/takosumi-contract/installer-api": [
        "./src/contract/installer-api.ts"
      ],
      "@takos/takosumi-contract/reference/compat": [
        "./src/contract/reference-compat.ts"
      ],
      "@takos/takosumi-contract/reference/error-category": [
        "./src/contract/error-category.ts"
      ],
      "@takos/takosumi-contract/reference/plugin": ["./src/contract/plugin.ts"],
      "@takos/takosumi-contract/reference/plugin-sdk": [
        "./src/contract/plugin-sdk.ts"
      ],
      "@takos/takosumi-contract/reference/runtime-agent": [
        "./src/contract/runtime-agent.ts"
      ],
      "@takos/takosumi-contract/reference/runtime-agent-lifecycle": [
        "./src/contract/runtime-agent-lifecycle.ts"
      ],
      "@takos/takosumi-contract/reference/runtime-capability": [
        "./src/contract/runtime-capability.ts"
      ],
      "@takos/takosumi-contract/reference/shape": ["./src/contract/shape.ts"],
      "@takos/takosumi-contract/reference/shape-validators": [
        "./src/contract/shape-validators.ts"
      ],
      "@takos/takosumi-contract/reference/types": ["./src/contract/types.ts"],
      "@takos/takosumi-contract/reference/types-validators": [
        "./src/contract/types-validators.ts"
      ],
      "@takos/takosumi-contract/internal/api": [
        "./src/contract/internal-api.ts"
      ],
      "@takos/takosumi-contract/internal/material": [
        "./src/contract/internal-material.ts"
      ],
      "@takos/takosumi-contract/internal/material-validators": [
        "./src/contract/internal-material-validators.ts"
      ],
      "@takos/takosumi-contract/internal/provider-plugin": [
        "./src/contract/provider-plugin.ts"
      ],
      "@takos/takosumi-contract/internal/rpc": [
        "./src/contract/internal-rpc.ts"
      ],
      "@takos/takosumi-kernel/runtime": ["./src/kernel/shared/runtime/mod.ts"],
      "takosumi-contract": ["./src/contract/mod.ts"],
      "takosumi-contract/app-spec": ["./src/contract/app-spec.ts"],
      "takosumi-contract/catalog": ["./src/contract/catalog.ts"],
      "takosumi-contract/installer-api": ["./src/contract/installer-api.ts"],
      "takosumi-contract/reference/compat": [
        "./src/contract/reference-compat.ts"
      ],
      "takosumi-contract/reference/error-category": [
        "./src/contract/error-category.ts"
      ],
      "takosumi-contract/reference/plugin": ["./src/contract/plugin.ts"],
      "takosumi-contract/reference/plugin-sdk": [
        "./src/contract/plugin-sdk.ts"
      ],
      "takosumi-contract/reference/runtime-agent": [
        "./src/contract/runtime-agent.ts"
      ],
      "takosumi-contract/reference/runtime-agent-lifecycle": [
        "./src/contract/runtime-agent-lifecycle.ts"
      ],
      "takosumi-contract/reference/runtime-capability": [
        "./src/contract/runtime-capability.ts"
      ],
      "takosumi-contract/reference/shape": ["./src/contract/shape.ts"],
      "takosumi-contract/reference/shape-validators": [
        "./src/contract/shape-validators.ts"
      ],
      "takosumi-contract/reference/types": ["./src/contract/types.ts"],
      "takosumi-contract/internal/api": ["./src/contract/internal-api.ts"],
      "takosumi-contract/internal/provider-plugin": [
        "./src/contract/provider-plugin.ts"
      ],
      "takosumi-contract/internal/rpc": ["./src/contract/internal-rpc.ts"],

      "takosumi-installer": ["./src/installer/mod.ts"],
      "takosumi-installer/yaml-parser": ["./src/installer/yaml-parser.ts"],
      "takosumi-installer/git-fetch": ["./src/installer/git-fetch.ts"],
      "takosumi-installer/deploy-client": ["./src/installer/deploy-client.ts"],
      "takosumi-runtime-agent/connectors": [
        "./src/runtime-agent/connectors/mod.ts"
      ],
      "takosumi-runtime-agent/prepared-source-reader": [
        "./src/runtime-agent/prepared_source_reader.ts"
      ]
    }
  },
  "include": ["src", "shims"],
  "exclude": [
    "**/*_test.ts",
    "src/cli/tests",
    "src/kernel/scripts"
  ]
}
