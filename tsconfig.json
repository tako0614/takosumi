        "./packages/accounts-service/src/mod.ts"
      ],
      "@takosjp/takosumi-accounts-cli": ["./packages/cli/src/main.ts"],
      "@takosjp/takosumi-accounts": ["./packages/all/src/mod.ts"],
      "@takosjp/takosumi-platform-services": [
