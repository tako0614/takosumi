{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/object-store",
  "@type": "ComponentKind",
  "name": "object-store",
  "version": "v1",
  "referenceAliases": ["object-store"],
  "description": "Bucket-style object storage intended to be bindable across compatible S3-class providers. Backend-specific placement, versioning, and public access controls belong to native object-store kinds.",
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name"],
    "additionalProperties": false,
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Logical bucket name (operator applies implementation scoping rules)."
      }
    }
  },
  "outputSlots": {
    "bucket": {
      "contract": "object-store",
      "exampleMaterialMapping": {
        "bucket": "$outputs.bucket",
        "endpoint": "$outputs.endpoint",
        "region": "$outputs.region",
        "accessKeyIdRef": { "secretRef": "$outputs.accessKeyIdRef" },
        "secretAccessKeyRef": { "secretRef": "$outputs.secretAccessKeyRef" }
      }
    }
  },
  "outputs": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "meaning": "Implementation-scoped bucket name."
    },
    {
      "name": "endpoint",
      "type": "string",
      "required": true,
      "meaning": "S3-class endpoint URL."
    },
    {
      "name": "region",
      "type": "string",
      "required": false,
      "meaning": "Bucket region."
    },
    {
      "name": "accessKeyIdRef",
      "type": "string",
      "required": false,
      "meaning": "Reference to secret store entry holding the access key id."
    },
    {
      "name": "secretAccessKeyRef",
      "type": "string",
      "required": false,
      "meaning": "Reference to secret store entry holding the secret access key."
    }
  ],
  "capabilityTerms": [
    "s3-compatible"
  ]
}
