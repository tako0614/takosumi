{
  "@context": "https://takosumi.com/reference/kernel/contexts/deploy.jsonld",
  "@id": "https://takosumi.com/reference/kernel/descriptors/authoring/composite-expansion/v1",
  "@type": "takosumi:AuthoringExpansionDescriptor",
  "shortRef": "authoring.composite-expansion@v1",
  "domain": "authoring",
  "lifecycleDomain": "shape-derivation",
  "changeEffect": "shape-derivation",
  "description": "Reference kernel internal authoring expansion that replaces a composite.* input with runtime, resource, and output contract instances before planning.",
  "expandsTo": [
    "InternalDeploySpec",
    "runtime contract input",
    "resource contract input"
  ],
  "invariants": [
    "expansion-before-plan",
    "descriptor-digest-pinned",
    "no-runtime-or-provider-semantics"
  ]
}
