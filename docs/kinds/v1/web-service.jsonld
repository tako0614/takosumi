{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/web-service",
  "@type": "ComponentKind",
  "name": "web-service",
  "version": "v1",
  "referenceAliases": [
    "web-service"
  ],
  "description": "Long-running HTTP service. `image` and `scale` are optional container-subset fields; the divergent systemd binding of this kind uses only `port` plus its own command and omits container-only fields. `healthCheck` and `volumes` are likewise OPTIONAL container-subset hints: backends that do not run containers (such as systemd) ignore or reject them at apply, exactly like the existing optional `image` and `scale`. `healthCheck.interval` and `healthCheck.timeout` are in SECONDS. `volumes[].source` is a logical, operator/binding-resolved volume name or URI (backend-neutral) and `volumes[].target` is an absolute container mount path.",
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
      "image",
      "port"
    ],
    "additionalProperties": false,
    "properties": {
      "image": {
        "type": "string",
        "minLength": 1,
        "description": "OCI image reference."
      },
      "port": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535,
        "description": "Container listen port exposed by the service."
      },
      "scale": {
        "type": "object",
        "required": [
          "min",
          "max"
        ],
        "additionalProperties": false,
        "description": "Replica bounds. `min: 0` requests zero steady replicas. Operator policy and the selected implementation materialize or reject the request.",
        "properties": {
          "min": {
            "type": "integer",
            "minimum": 0,
            "description": "Minimum requested replica count."
          },
          "max": {
            "type": "integer",
            "minimum": 1,
            "description": "Maximum requested replica count."
          }
        }
      },
      "env": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Environment variables passed to the service."
      },
      "resources": {
        "type": "object",
        "additionalProperties": false,
        "description": "CPU / memory hints consumed by compatible provider bindings.",
        "properties": {
          "cpu": {
            "type": "string",
            "minLength": 1,
            "description": "Requested CPU size or provider-specific CPU class."
          },
          "memory": {
            "type": "string",
            "minLength": 1,
            "description": "Requested memory size or provider-specific memory class."
          }
        }
      },
      "healthCheck": {
        "type": "object",
        "additionalProperties": false,
        "description": "Optional container-subset health probe hint. Container backends use it to gate readiness and restart unhealthy instances; non-container backends (such as the divergent systemd binding) ignore or reject it at apply.",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "HTTP path probed for liveness, such as `/healthz`."
          },
          "interval": {
            "type": "integer",
            "minimum": 1,
            "description": "Seconds between health probes."
          },
          "timeout": {
            "type": "integer",
            "minimum": 1,
            "description": "Seconds to wait for a single probe response before it counts as a failure."
          },
          "unhealthyThreshold": {
            "type": "integer",
            "minimum": 1,
            "description": "Consecutive failed probes before the instance is treated as unhealthy."
          },
          "readinessPath": {
            "type": "string",
            "minLength": 1,
            "description": "HTTP path probed for readiness before the instance receives traffic, such as `/readyz`."
          }
        }
      },
      "volumes": {
        "type": "array",
        "description": "Optional container-subset volume mounts. Container backends attach each logical volume at the given mount path; non-container backends (such as the divergent systemd binding) ignore or reject them at apply.",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "target"
          ],
          "description": "A single logical volume mount.",
          "properties": {
            "source": {
              "type": "string",
              "minLength": 1,
              "description": "Logical volume name or URI resolved by the operator / implementation binding (backend-neutral)."
            },
            "target": {
              "type": "string",
              "minLength": 1,
              "description": "Absolute container mount path, such as `/var/lib/data`."
            },
            "persistent": {
              "type": "boolean",
              "description": "Whether the volume must survive instance restarts. Omitted means the implementation binding decides."
            }
          }
        }
      }
    }
  },
  "outputSlots": {
    "http": {
      "contract": "http-endpoint",
      "exampleMaterialMapping": {
        "targets": [
          {
            "name": "default",
            "url": "$outputs.url",
            "host": "$outputs.internalHost",
            "port": "$outputs.internalPort",
            "visibility": "private"
          }
        ]
      }
    }
  },
  "listens": {
    "*": {
      "accepts": [
        "http-endpoint",
        "service-binding",
        "object-store",
        "event-channel",
        "identity.oidc@v1",
        "billing.port@v1",
        "mcp-server@v1"
      ],
      "projectionFamilies": [
        "env",
        "secret-env",
        "config-mount",
        "upstream"
      ],
      "projectionMatrix": {
        "http-endpoint": [
          "env",
          "config-mount",
          "upstream"
        ],
        "service-binding": [
          "secret-env",
          "config-mount"
        ],
        "object-store": [
          "secret-env",
          "config-mount"
        ],
        "event-channel": [
          "secret-env",
          "config-mount"
        ],
        "identity.oidc@v1": [
          "secret-env",
          "config-mount"
        ],
        "billing.port@v1": [
          "secret-env",
          "config-mount"
        ],
        "mcp-server@v1": [
          "secret-env",
          "config-mount"
        ]
      }
    }
  },
  "outputs": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "meaning": "Implementation-local upstream URL (scheme-bearing) used by gateway/listener components."
    },
    {
      "name": "internalHost",
      "type": "string",
      "required": true,
      "meaning": "Implementation-local service host."
    },
    {
      "name": "internalPort",
      "type": "integer",
      "required": true,
      "meaning": "Implementation-local service port."
    }
  ],
  "capabilityTerms": [
    "http-service",
    "oci-image",
    "replica-scaling",
    "container-health-check",
    "persistent-volume"
  ]
}
