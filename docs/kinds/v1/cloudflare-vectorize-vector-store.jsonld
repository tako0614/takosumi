{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/cloudflare-vectorize-vector-store",
  "@type": "ComponentKind",
  "name": "cloudflare-vectorize-vector-store",
  "version": "v1",
  "description": "Cloudflare Vectorize index binding. Publishes vector index identity as service-binding material.",
  "family": "vector-store",
  "portableBase": "https://takosumi.com/kinds/v1/vector-store",
  "referenceAliases": ["cloudflare-vectorize-vector-store"],
  "publications": {
    "index": {
      "contract": "service-binding",
      "exampleMaterialMapping": {
        "service": "$outputs.indexId",
        "protocol": "vector"
      }
    }
  },
  "capabilityTerms": ["vector-upsert", "vector-query", "vector-delete", "cloudflare-vectorize"],
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name", "dimensions", "metric"],
    "additionalProperties": false,
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Vectorize index name."
      },
      "dimensions": {
        "type": "integer",
        "minimum": 1,
        "description": "Vector dimensions."
      },
      "metric": {
        "type": "string",
        "enum": ["cosine", "euclidean", "dot-product"],
        "description": "Distance metric."
      }
    }
  },
  "outputs": [
    {
      "name": "indexId",
      "type": "string",
      "required": true,
      "meaning": "Cloudflare Vectorize index identifier."
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "meaning": "Vectorize index name."
    }
  ]
}
