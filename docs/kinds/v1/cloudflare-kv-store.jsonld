{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/cloudflare-kv-store",
  "@type": "ComponentKind",
  "name": "cloudflare-kv-store",
  "version": "v1",
  "description": "Cloudflare KV store binding. Publishes store identity as service-binding material.",
  "family": "kv-store",
  "portableBase": "https://takosumi.com/kinds/v1/kv-store",
  "referenceAliases": ["cloudflare-kv-store"],
  "publications": {
    "store": {
      "contract": "service-binding",
      "exampleMaterialMapping": {
        "service": "$outputs.storeId",
        "protocol": "kv"
      }
    }
  },
  "capabilityTerms": ["kv-read-write", "kv-list", "cloudflare-kv"],
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name"],
    "additionalProperties": false,
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "KV namespace title."
      }
    }
  },
  "outputs": [
    {
      "name": "storeId",
      "type": "string",
      "required": true,
      "meaning": "Cloudflare KV namespace identifier."
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "meaning": "KV namespace title."
    }
  ]
}
