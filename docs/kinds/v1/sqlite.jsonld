{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/sqlite",
  "@type": "ComponentKind",
  "name": "sqlite",
  "version": "v1",
  "referenceAliases": ["sqlite"],
  "description": "SQLite-compatible database for relational state in small and edge-oriented workloads.",
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name"],
    "additionalProperties": false,
    "properties": {
      "name": { "type": "string", "minLength": 1, "description": "Database name." }
    }
  },
  "outputSlots": {
    "connection": {
      "contract": "service-binding",
      "exampleMaterialMapping": {
        "service": "$outputs.databaseId",
        "protocol": "sqlite",
        "connectionUrl": "$outputs.url",
        "tokenRef": { "secretRef": "$outputs.tokenSecretRef" }
      }
    }
  },
  "outputs": [
    { "name": "databaseId", "type": "string", "required": true, "meaning": "Implementation-scoped database identifier." },
    { "name": "name", "type": "string", "required": true, "meaning": "Database name." },
    { "name": "url", "type": "string", "required": false, "meaning": "Connection URL if the implementation exposes one." },
    { "name": "tokenSecretRef", "type": "string", "required": false, "meaning": "Secret reference for clients that need token-based access." }
  ],
  "capabilityTerms": ["sqlite-wire", "managed-credentials"]
}
