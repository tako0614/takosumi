{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/docker-compose-web-service",
  "@type": "ComponentKind",
  "name": "docker-compose-web-service",
  "version": "v1",
  "description": "Docker Compose web service binding for an OCI image on a local or operator-managed host. Publishes an implementation-local HTTP upstream endpoint.",
  "family": "web-service",
  "portableBase": "https://takosumi.com/kinds/v1/web-service",
  "referenceAliases": [
    "docker-compose-web-service"
  ],
  "publications": {
    "http": {
      "contract": "http-endpoint",
      "exampleMaterialMapping": {
        "targets": [
          {
            "name": "default",
            "url": "$outputs.url",
            "host": "$outputs.internalHost",
            "port": "$outputs.internalPort",
            "visibility": "private"
          }
        ]
      }
    }
  },
  "capabilityTerms": [
    "always-on",
    "websocket",
    "long-request"
  ],
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
      "image",
      "port"
    ],
    "additionalProperties": false,
    "properties": {
      "image": {
        "type": "string",
        "minLength": 1,
        "description": "OCI image reference."
      },
      "port": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535,
        "description": "Container listen port exposed by the service."
      },
      "env": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Environment variables passed to the service."
      },
      "command": {
        "type": "array",
        "description": "Container command override passed to local host-oriented web-service backends.",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "listens": {
    "*": {
      "accepts": [
        "http-endpoint",
        "service-binding",
        "object-store",
        "event-channel",
        "identity.oidc@v1",
        "billing.port@v1",
        "mcp-server@v1"
      ],
      "projectionFamilies": [
        "env",
        "secret-env",
        "config-mount",
        "upstream"
      ],
      "projectionMatrix": {
        "http-endpoint": [
          "env",
          "config-mount",
          "upstream"
        ],
        "service-binding": [
          "secret-env",
          "config-mount"
        ],
        "object-store": [
          "secret-env",
          "config-mount"
        ],
        "event-channel": [
          "secret-env",
          "config-mount"
        ],
        "identity.oidc@v1": [
          "secret-env",
          "config-mount"
        ],
        "billing.port@v1": [
          "secret-env",
          "config-mount"
        ],
        "mcp-server@v1": [
          "secret-env",
          "config-mount"
        ]
      }
    }
  },
  "outputs": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "meaning": "Implementation-local upstream URL (scheme-bearing) used by gateway/listener components."
    },
    {
      "name": "internalHost",
      "type": "string",
      "required": true,
      "meaning": "Implementation-local service host."
    },
    {
      "name": "internalPort",
      "type": "integer",
      "required": true,
      "meaning": "Implementation-local service port."
    }
  ]
}
