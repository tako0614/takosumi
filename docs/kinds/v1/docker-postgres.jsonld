{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/docker-postgres",
  "@type": "ComponentKind",
  "name": "docker-postgres",
  "version": "v1",
  "description": "Docker-backed PostgreSQL binding for local or single-host profiles. Publishes PostgreSQL service binding material and a password secret reference.",
  "family": "postgres",
  "portableBase": "https://takosumi.com/kinds/v1/postgres",
  "referenceAliases": [
    "docker-postgres"
  ],
  "publications": {
    "connection": {
      "contract": "service-binding",
      "exampleMaterialMapping": {
        "service": "$outputs.host",
        "protocol": "postgresql",
        "host": "$outputs.host",
        "port": "$outputs.port",
        "database": "$outputs.database",
        "username": "$outputs.username",
        "passwordRef": {
          "secretRef": "$outputs.passwordSecretRef"
        },
        "connectionUrl": "$outputs.connectionString"
      }
    }
  },
  "capabilityTerms": [
    "local-docker"
  ],
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
      "version"
    ],
    "additionalProperties": false,
    "properties": {
      "version": {
        "type": "string",
        "minLength": 1,
        "description": "PostgreSQL major version string (e.g. `15`, `16`)."
      }
    }
  },
  "outputs": [
    {
      "name": "host",
      "type": "string",
      "required": true,
      "meaning": "Database hostname."
    },
    {
      "name": "port",
      "type": "integer",
      "required": true,
      "meaning": "TCP port (typically 5432)."
    },
    {
      "name": "database",
      "type": "string",
      "required": true,
      "meaning": "Database name."
    },
    {
      "name": "username",
      "type": "string",
      "required": true,
      "meaning": "Connection username (role name)."
    },
    {
      "name": "passwordSecretRef",
      "type": "string",
      "required": true,
      "meaning": "Reference to secret store entry holding password."
    },
    {
      "name": "connectionString",
      "type": "string",
      "required": true,
      "meaning": "Passwordless client connection URL. Credentials are supplied through passwordSecretRef."
    }
  ]
}
