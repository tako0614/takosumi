{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/cloudflare-worker",
  "@type": "ComponentKind",
  "name": "cloudflare-worker",
  "version": "v1",
  "description": "Cloudflare Workers JavaScript worker binding. Publishes an implementation-local HTTP upstream target for gateway/listener components.",
  "family": "worker",
  "portableBase": "https://takosumi.com/kinds/v1/worker",
  "referenceAliases": [
    "cloudflare-worker"
  ],
  "publications": {
    "http": {
      "contract": "http-endpoint",
      "exampleMaterialMapping": {
        "targets": [
          {
            "name": "default",
            "url": "$outputs.url",
            "visibility": "private"
          }
        ]
      }
    }
  },
  "capabilityTerms": [
    "scale-to-zero",
    "websocket",
    "long-request",
    "geo-routing"
  ],
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
      "entrypoint"
    ],
    "additionalProperties": false,
    "properties": {
      "entrypoint": {
        "type": "string",
        "minLength": 1,
        "description": "Source-root-relative worker module path inside the resolved source view."
      },
      "env": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Optional env vars / bindings."
      },
      "compatibilityDate": {
        "type": "string",
        "minLength": 1,
        "description": "Runtime compatibility date understood by the selected worker backend."
      },
      "compatibilityFlags": {
        "type": "array",
        "description": "Runtime compatibility flags understood by the selected worker backend.",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "listens": {
    "*": {
      "accepts": [
        "http-endpoint",
        "service-binding",
        "object-store",
        "event-channel",
        "identity.oidc@v1",
        "billing.port@v1",
        "mcp-server@v1"
      ],
      "projectionFamilies": [
        "env",
        "secret-env",
        "config-mount",
        "upstream"
      ],
      "projectionMatrix": {
        "http-endpoint": [
          "env",
          "config-mount",
          "upstream"
        ],
        "service-binding": [
          "secret-env",
          "config-mount"
        ],
        "object-store": [
          "secret-env",
          "config-mount"
        ],
        "event-channel": [
          "secret-env",
          "config-mount"
        ],
        "identity.oidc@v1": [
          "secret-env",
          "config-mount"
        ],
        "billing.port@v1": [
          "secret-env",
          "config-mount"
        ],
        "mcp-server@v1": [
          "secret-env",
          "config-mount"
        ]
      }
    }
  },
  "outputs": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "meaning": "Implementation-local upstream URL (scheme-bearing) used by gateway/listener components."
    },
    {
      "name": "id",
      "type": "string",
      "required": true,
      "meaning": "Implementation-scoped worker identifier."
    },
    {
      "name": "version",
      "type": "string",
      "required": false,
      "meaning": "Current deployed worker version."
    }
  ]
}
