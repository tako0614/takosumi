{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/cloudflare-d1-sqlite",
  "@type": "ComponentKind",
  "name": "cloudflare-d1-sqlite",
  "version": "v1",
  "description": "Cloudflare D1 database binding. Publishes SQLite-compatible service binding material.",
  "family": "sqlite",
  "portableBase": "https://takosumi.com/kinds/v1/sqlite",
  "referenceAliases": ["cloudflare-d1-sqlite"],
  "publications": {
    "connection": {
      "contract": "service-binding",
      "exampleMaterialMapping": {
        "service": "$outputs.databaseId",
        "protocol": "sqlite",
        "database": "$outputs.name"
      }
    }
  },
  "capabilityTerms": ["managed-credentials", "cloudflare-d1"],
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name"],
    "additionalProperties": false,
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "D1 database name."
      },
      "primaryLocationHint": {
        "type": "string",
        "enum": ["WNAM", "ENAM", "WEUR", "EEUR", "APAC", "OC"],
        "description": "Cloudflare D1 primary location hint. Ignored when jurisdiction is set."
      },
      "jurisdiction": {
        "type": "string",
        "enum": ["eu", "fedramp"],
        "description": "Cloudflare D1 jurisdiction restriction."
      }
    }
  },
  "outputs": [
    {
      "name": "databaseId",
      "type": "string",
      "required": true,
      "meaning": "Cloudflare D1 database identifier."
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "meaning": "D1 database name."
    }
  ]
}
