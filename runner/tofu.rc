# Baked OpenTofu CLI config for the runner container (TF_CLI_CONFIG_FILE).
#
# plugin_cache_dir: shared on-disk plugin cache so repeated inits in the same
#   image reuse already-extracted provider binaries.
#
# provider_installation:
#   filesystem_mirror is authoritative for the providers pre-mirrored into the
#   image at build time (cloudflare/cloudflare, hashicorp/random, hashicorp/tls,
#   hashicorp/aws). `direct { exclude = [...] }` forbids the registry/network path
#   for exactly those providers, so a `tofu init` for bundled first-party modules
#   resolves them from disk with no network — which is what lets plan run under
#   `--network none`. aws is mirrored so the first-party `aws-s3-storage` Capsule
#   no longer fail-closes under offline init. Any provider NOT in these lists
#   (e.g. google, not yet mirrored for size) falls through to `direct` and is
#   fetched from the registry as usual.

plugin_cache_dir = "/opt/opentofu/provider-cache"

provider_installation {
  filesystem_mirror {
    path = "/opt/opentofu/provider-mirror"
    include = [
      "registry.opentofu.org/cloudflare/cloudflare",
      "registry.opentofu.org/hashicorp/random",
      "registry.opentofu.org/hashicorp/tls",
      "registry.opentofu.org/hashicorp/aws",
    ]
  }
  direct {
    exclude = [
      "registry.opentofu.org/cloudflare/cloudflare",
      "registry.opentofu.org/hashicorp/random",
      "registry.opentofu.org/hashicorp/tls",
      "registry.opentofu.org/hashicorp/aws",
    ]
  }
}
