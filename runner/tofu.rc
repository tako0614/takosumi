# Baked OpenTofu CLI config for the runner container (TF_CLI_CONFIG_FILE).
#
# provider_installation is provider-neutral: every provider may be resolved from
# the image mirror when present and from its ordinary registry otherwise. A run
# that requires mirror-only installation gets a generated CLI config with an
# explicit provider allowlist and a disabled direct path. Runtime-generated
# per-run CLI configs may use a run-local cache or the operator-configured
#   TAKOSUMI_OPENTOFU_PLUGIN_CACHE_DIR for provider binaries only; this baked
#   fallback deliberately has no shared mutable plugin cache.

provider_installation {
  filesystem_mirror {
    path = "/opt/opentofu/provider-mirror"
  }
  direct {}
}
