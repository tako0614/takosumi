{
  "name": "@takos/takosumi",
  "version": "0.17.0",
  "license": "MIT",
  "exports": {
    ".": "./src/all/mod.ts",
    "./contract": "./src/contract/mod.ts",
    "./installer": "./src/installer/mod.ts",
    "./kernel": "./src/all/kernel.ts",
    "./cli": "./src/all/cli.ts",
    "./runtime-agent": "./src/runtime-agent/server.ts",
    "./server": "./src/all/server.ts"
  },
  "imports": {
    "takosumi-contract": "./src/contract/mod.ts",
    "takosumi-contract/app-spec": "./src/contract/app-spec.ts",
    "takosumi-contract/catalog": "./src/contract/catalog.ts",
    "takosumi-contract/installer-api": "./src/contract/installer-api.ts",
    "takosumi-contract/reference/compat": "./src/contract/reference-compat.ts",
    "takosumi-contract/reference/error-category": "./src/contract/error-category.ts",
    "takosumi-contract/reference/plugin": "./src/contract/plugin.ts",
    "takosumi-contract/reference/plugin-sdk": "./src/contract/plugin-sdk.ts",
    "takosumi-contract/reference/runtime-agent": "./src/contract/runtime-agent.ts",
    "takosumi-contract/reference/runtime-agent-lifecycle": "./src/contract/runtime-agent-lifecycle.ts",
    "takosumi-contract/reference/runtime-capability": "./src/contract/runtime-capability.ts",
    "takosumi-contract/reference/shape": "./src/contract/shape.ts",
    "takosumi-contract/reference/shape-validators": "./src/contract/shape-validators.ts",
    "takosumi-contract/reference/types": "./src/contract/types.ts",
    "takosumi-contract/internal/api": "./src/contract/internal-api.ts",
    "takosumi-contract/internal/provider-plugin": "./src/contract/provider-plugin.ts",
    "takosumi-contract/internal/rpc": "./src/contract/internal-rpc.ts",
    "@takos/takosumi-contract": "./src/contract/mod.ts",
    "@takos/takosumi-contract/app-spec": "./src/contract/app-spec.ts",
    "@takos/takosumi-contract/catalog": "./src/contract/catalog.ts",
    "@takos/takosumi-contract/installer-api": "./src/contract/installer-api.ts",
    "@takos/takosumi-contract/reference/compat": "./src/contract/reference-compat.ts",
    "@takos/takosumi-contract/reference/error-category": "./src/contract/error-category.ts",
    "@takos/takosumi-contract/reference/plugin": "./src/contract/plugin.ts",
    "@takos/takosumi-contract/reference/plugin-sdk": "./src/contract/plugin-sdk.ts",
    "@takos/takosumi-contract/reference/runtime-agent": "./src/contract/runtime-agent.ts",
    "@takos/takosumi-contract/reference/runtime-agent-lifecycle": "./src/contract/runtime-agent-lifecycle.ts",
    "@takos/takosumi-contract/reference/runtime-capability": "./src/contract/runtime-capability.ts",
    "@takos/takosumi-contract/reference/shape": "./src/contract/shape.ts",
    "@takos/takosumi-contract/reference/shape-validators": "./src/contract/shape-validators.ts",
    "@takos/takosumi-contract/reference/types": "./src/contract/types.ts",
    "@takos/takosumi-contract/internal/api": "./src/contract/internal-api.ts",
    "@takos/takosumi-contract/internal/provider-plugin": "./src/contract/provider-plugin.ts",
    "@takos/takosumi-contract/internal/rpc": "./src/contract/internal-rpc.ts",
    "takosumi-installer": "./src/installer/mod.ts",
    "takosumi-installer/yaml-parser": "./src/installer/yaml-parser.ts",
    "takosumi-installer/git-fetch": "./src/installer/git-fetch.ts",
    "takosumi-installer/deploy-client": "./src/installer/deploy-client.ts",
    "@takos/takosumi-installer": "./src/installer/mod.ts",
    "@takos/takosumi-installer/yaml-parser": "./src/installer/yaml-parser.ts",
    "@takos/takosumi-installer/git-fetch": "./src/installer/git-fetch.ts",
    "@takos/takosumi-installer/deploy-client": "./src/installer/deploy-client.ts",
    "@takos/takosumi-kernel": "./src/kernel/bootstrap.ts",
    "@takos/takosumi-kernel/adapters": "./src/kernel/adapters/mod.ts",
    "@takos/takosumi-kernel/agents": "./src/kernel/agents/mod.ts",
    "@takos/takosumi-kernel/api": "./src/kernel/api/mod.ts",
    "@takos/takosumi-kernel/app_context": "./src/kernel/app_context.ts",
    "@takos/takosumi-kernel/bootstrap": "./src/kernel/bootstrap.ts",
    "@takos/takosumi-kernel/plugins": "./src/kernel/plugins/mod.ts",
    "@takos/takosumi-kernel/runtime": "./src/kernel/shared/runtime/index.ts",
    "@takos/takosumi-kernel/server": "./src/kernel/index.ts",
    "@takos/takosumi-cli": "./src/cli/main.ts",
    "@takos/takosumi-runtime-agent": "./src/runtime-agent/server.ts",
    "@takos/takosumi-runtime-agent/server": "./src/runtime-agent/server.ts",
    "@takos/takosumi-runtime-agent/embed": "./src/runtime-agent/embed.ts",
    "@takos/takosumi-runtime-agent/connectors": "./src/runtime-agent/connectors/mod.ts",
    "@takos/takosumi-runtime-agent/prepared-source-reader": "./src/runtime-agent/prepared_source_reader.ts",
    "@takos/takosumi-runtime-agent/dispatcher": "./src/runtime-agent/lifecycle_dispatcher.ts",
    "@takos/takosumi-runtime-agent/artifact-fetcher": "./src/runtime-agent/artifact_fetcher.ts",
    "takosumi-runtime-agent/connectors": "./src/runtime-agent/connectors/mod.ts",
    "takosumi-runtime-agent/prepared-source-reader": "./src/runtime-agent/prepared_source_reader.ts",
    "hono": "npm:hono@^4.12.4",
    "@std/yaml": "jsr:@std/yaml@^1.0.0",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0-rc.7"
  },
  "compilerOptions": {
    "strict": true,
    "lib": [
      "deno.window",
      "dom",
      "dom.iterable"
    ],
    "types": [
      "node"
    ]
  },
  "lint": {
    "exclude": [
      "website/.output",
      "website/.vinxi"
    ],
    "rules": {
      "exclude": [
        "no-import-prefix",
        "no-process-global",
        "no-slow-types",
        "no-unversioned-import"
      ]
    }
  },
  "tasks": {
    "check": "deno check src/contract/mod.ts src/contract/*_test.ts src/runtime-agent/server.ts src/runtime-agent/embed.ts src/runtime-agent/connectors/mod.ts src/runtime-agent/prepared_source_reader.ts src/kernel/index.ts scripts/live-provisioning-smoke.ts scripts/public-spec-source-map_test.ts scripts/kind-descriptor-material-mapping_test.ts scripts/kind-package-ownership_test.ts",
    "check:cloudflare": "deno check --config deploy/cloudflare/deno.json deploy/cloudflare/src/worker.ts deploy/cloudflare/src/worker_test.ts deploy/cloudflare/src/scaffold_test.ts",
    "test": "deno test --allow-all",
    "live-provisioning-smoke": "deno run --allow-read --allow-env --allow-net scripts/live-provisioning-smoke.ts",
    "live-provisioning-smoke:fixture:all": "deno run --allow-read --allow-env --allow-net scripts/live-provisioning-smoke.ts --fixture-all",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "lint:json-ld": "deno run --allow-read scripts/lint-json-ld.ts",
    "spec:build": "bash -c 'mkdir -p website/.output/public/contexts && cp -R spec/contexts/. website/.output/public/contexts/ && echo \"[takosumi/spec] published spec/contexts → website/.output/public/contexts/\"'",
    "docs:install": "cd docs && npm install",
    "docs:dev": "cd docs && npx vitepress dev",
    "docs:build": "cd docs && npx vitepress build",
    "docs:preview": "cd docs && npx vitepress preview",
    "website:build": "bash website/build.sh",
    "website:preview": "bash website/build.sh && npx wrangler pages dev website/.output/public --port 8788",
    "website:deploy": "bash website/build.sh && npx wrangler pages deploy website/.output/public --project-name=takosumi-website"
  },
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "docs/.vitepress/cache",
      "docs/.vitepress/dist",
      "docs/node_modules",
      "website/.output",
      "website/.vinxi"
    ]
  }
}
