    "@takos/takosumi-runtime-agent/artifact-fetcher": "./src/runtime-agent/artifact_fetcher.ts",
    "takosumi-runtime-agent/connectors": "./src/runtime-agent/connectors/mod.ts",
    "takosumi-runtime-agent/prepared-source-reader": "./src/runtime-agent/prepared_source_reader.ts",
    "@takos/takosumi-kind-worker": "./src/kinds/worker/mod.ts",
    "@takos/takosumi-kind-web-service": "./src/kinds/web-service/mod.ts",
    "@takos/takosumi-kind-postgres": "./src/kinds/postgres/mod.ts",
    "@takos/takosumi-kind-sqlite": "./src/kinds/sqlite/mod.ts",
    "@takos/takosumi-kind-object-store": "./src/kinds/object-store/mod.ts",
    "@takos/takosumi-kind-kv-store": "./src/kinds/kv-store/mod.ts",
    "@takos/takosumi-kind-message-queue": "./src/kinds/message-queue/mod.ts",
    "@takos/takosumi-kind-vector-store": "./src/kinds/vector-store/mod.ts",
    "@takos/takosumi-kind-gateway": "./src/kinds/gateway/mod.ts",
    "hono": "npm:hono@^4.12.4",
    "@std/yaml": "jsr:@std/yaml@^1.0.0",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0-rc.7"
  },
  "compilerOptions": {
    "strict": true,
    "lib": [
      "deno.window",
      "dom",
      "dom.iterable"
    ],
    "types": [
      "node"
    ]
  },
  "lint": {
    "exclude": [
      "website/.output",
      "website/.vinxi"
    ],
    "rules": {
      "exclude": [
        "no-import-prefix",
        "no-process-global",
        "no-slow-types",
        "no-unversioned-import"
      ]
    }
  },
  "tasks": {
    "check": "deno check packages/contract/mod.ts packages/contract/src/*_test.ts packages/runtime-agent/src/server.ts packages/runtime-agent/src/embed.ts packages/runtime-agent/src/connectors/mod.ts packages/runtime-agent/src/prepared_source_reader.ts src/kinds/worker/mod.ts src/kinds/web-service/mod.ts src/kinds/postgres/mod.ts src/kinds/object-store/mod.ts src/kinds/gateway/mod.ts src/kinds/sqlite/mod.ts src/kinds/kv-store/mod.ts src/kinds/message-queue/mod.ts src/kinds/vector-store/mod.ts packages/kernel/src/index.ts scripts/live-provisioning-smoke.ts scripts/jsr-publish-dry-run.ts scripts/jsr-package-readiness.ts scripts/jsr-package-readiness_test.ts scripts/public-spec-source-map_test.ts scripts/kind-descriptor-material-mapping_test.ts scripts/kind-package-ownership_test.ts scripts/portable-kind-validation_test.ts scripts/portable-package-readme.ts scripts/spec-generate-ts.ts scripts/spec-check-drift.ts scripts/spec-check-drift_test.ts",
    "check:cloudflare": "deno check --config deploy/cloudflare/deno.json deploy/cloudflare/src/worker.ts deploy/cloudflare/src/worker_test.ts deploy/cloudflare/src/scaffold_test.ts",
    "test": "deno test --allow-all",
    "publish:dry-run": "deno run --allow-run --allow-read scripts/jsr-publish-dry-run.ts",
    "publish:check-jsr-records": "deno run --allow-net=jsr.io,api.jsr.io scripts/jsr-package-readiness.ts",
    "publish:jsr": "deno run --allow-run --allow-read --allow-env=JSR_TOKEN --allow-net=jsr.io,api.jsr.io scripts/jsr-publish-dry-run.ts --publish",
    "live-provisioning-smoke": "deno run --allow-read --allow-env --allow-net scripts/live-provisioning-smoke.ts",
    "live-provisioning-smoke:fixture:all": "deno run --allow-read --allow-env --allow-net scripts/live-provisioning-smoke.ts --fixture-all",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "lint:json-ld": "deno run --allow-read scripts/lint-json-ld.ts",
    "readme:generate": "deno run --allow-read --allow-write --allow-run scripts/portable-package-readme.ts",
    "readme:check": "deno run --allow-read --allow-write --allow-run scripts/portable-package-readme.ts --check",
    "spec:generate-ts": "deno run --allow-read --allow-write --allow-run scripts/spec-generate-ts.ts",
    "spec:check-drift": "deno run --allow-read --allow-write --allow-run scripts/spec-check-drift.ts",
    "spec:build": "bash -c 'mkdir -p website/.output/public/contexts && cp -R spec/contexts/. website/.output/public/contexts/ && echo \"[takosumi/spec] published spec/contexts → website/.output/public/contexts/\"'",
    "docs:install": "cd docs && npm install",
    "docs:dev": "cd docs && npx vitepress dev",
    "docs:build": "cd docs && npx vitepress build",
    "docs:preview": "cd docs && npx vitepress preview",
    "website:build": "bash website/build.sh",
    "website:preview": "bash website/build.sh && npx wrangler pages dev website/.output/public --port 8788",
    "website:deploy": "bash website/build.sh && npx wrangler pages deploy website/.output/public --project-name=takosumi-website"
  },
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "docs/.vitepress/cache",
      "docs/.vitepress/dist",
      "docs/node_modules",
      "website/.output",
      "website/.vinxi"
    ]
  }
}
