{
  "workspace": [
    "./packages/contract",
    "./packages/runtime-agent",
    "./packages/plugins",
    "./packages/kernel",
    "./packages/cli",
    "./packages/all",
    "./deploy/cloudflare"
  ],
  "imports": {
    "takosumi-contract": "./packages/contract/mod.ts",
    "takosumi-contract/core-v1": "./packages/contract/src/core-v1.ts",
    "takosumi-contract/error-category": "./packages/contract/src/error-category.ts",
    "takosumi-contract/internal-api": "./packages/contract/src/internal-api.ts",
    "takosumi-contract/internal-rpc": "./packages/contract/src/internal-rpc.ts",
    "takosumi-contract/manifest-resource": "./packages/contract/src/manifest-resource.ts",
    "takosumi-contract/plugin": "./packages/contract/src/plugin.ts",
    "takosumi-contract/plugin-sdk": "./packages/contract/src/plugin-sdk.ts",
    "takosumi-contract/provider-plugin": "./packages/contract/src/provider-plugin.ts",
    "takosumi-contract/runtime-agent": "./packages/contract/src/runtime-agent.ts",
    "takosumi-contract/runtime-agent-lifecycle": "./packages/contract/src/runtime-agent-lifecycle.ts",
    "takosumi-contract/shape": "./packages/contract/src/shape.ts",
    "takosumi-contract/template": "./packages/contract/src/template.ts",
    "takosumi-contract/types": "./packages/contract/src/types.ts",
    "hono": "npm:hono@^4.12.4"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "dom", "dom.iterable"],
    "types": ["node"]
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-import-prefix",
        "no-process-global",
        "no-unversioned-import"
      ]
    }
  },
  "tasks": {
    "check": "deno check packages/plugins/src/mod.ts packages/kernel/src/index.ts scripts/live-provisioning-smoke.ts scripts/jsr-publish-dry-run.ts scripts/public-spec-source-map_test.ts",
    "check:cloudflare": "deno check --config deploy/cloudflare/deno.json deploy/cloudflare/src/worker.ts deploy/cloudflare/src/worker_test.ts deploy/cloudflare/src/scaffold_test.ts",
    "test": "deno test --allow-all",
    "publish:dry-run": "deno run --allow-run --allow-read scripts/jsr-publish-dry-run.ts",
    "publish:jsr": "deno run --allow-run --allow-read scripts/jsr-publish-dry-run.ts --publish",
    "live-provisioning-smoke": "deno run --allow-read --allow-env --allow-net scripts/live-provisioning-smoke.ts",
    "live-provisioning-smoke:fixture:all": "deno run --allow-read --allow-env --allow-net scripts/live-provisioning-smoke.ts --fixture-all",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "docs:install": "cd docs && npm install",
    "docs:dev": "cd docs && npx vitepress dev",
    "docs:build": "cd docs && npx vitepress build",
    "docs:preview": "cd docs && npx vitepress preview"
  },
  "fmt": {
    "exclude": [
      "docs/.vitepress/cache",
      "docs/.vitepress/dist",
      "docs/node_modules"
    ]
  }
}
