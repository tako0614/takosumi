{
  "@context": "https://takosumi.com/contexts/v1.jsonld",
  "@id": "https://takosumi.com/kinds/v1/postgres",
  "@type": "ComponentKind",
  "name": "postgres",
  "version": "v1",
  "aliases": ["postgres"],
  "description": "Managed PostgreSQL instance. Provider-portable via standard wire protocol. Publishes connection material to the sibling namespace path.",
  "x-ts": {
    "fileBasename": "database-postgres",
    "prefix": "DatabasePostgres",
    "shapeId": "database-postgres"
  },
  "spec": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["version", "size"],
    "additionalProperties": false,
    "properties": {
      "version": {
        "type": "string",
        "minLength": 1,
        "description": "PostgreSQL major version string (e.g. `15`, `16`)."
      },
      "size": {
        "type": "string",
        "enum": ["small", "medium", "large", "xlarge"],
        "description": "Instance size class."
      },
      "storage": {
        "type": "object",
        "required": ["sizeGiB"],
        "description": "Persistent volume sizing.",
        "properties": {
          "sizeGiB": { "type": "integer", "minimum": 1 },
          "type": { "type": "string", "enum": ["ssd", "hdd"] }
        }
      },
      "backups": {
        "type": "object",
        "required": ["enabled"],
        "description": "Managed backup policy.",
        "properties": {
          "enabled": { "type": "boolean" },
          "retentionDays": { "type": "integer", "minimum": 1 }
        }
      },
      "highAvailability": {
        "type": "boolean",
        "description": "Enable provider-managed HA replica."
      },
      "extensions": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "description": "PostgreSQL extensions to enable (e.g. `pgvector`)."
      }
    }
  },
  "publishes": [
    {
      "namespacePath": "<app-id>.<component-name>",
      "material": {
        "host": "$outputs.host",
        "port": "$outputs.port",
        "database": "$outputs.database",
        "username": "$outputs.username",
        "passwordSecretRef": "$outputs.passwordSecretRef",
        "connectionString": "$outputs.connectionString"
      }
    }
  ],
  "listens": {},
  "outputs": [
    {
      "name": "host",
      "type": "string",
      "required": true,
      "meaning": "Database hostname."
    },
    {
      "name": "port",
      "type": "integer",
      "required": true,
      "meaning": "TCP port (typically 5432)."
    },
    {
      "name": "database",
      "type": "string",
      "required": true,
      "meaning": "Database name."
    },
    {
      "name": "username",
      "type": "string",
      "required": true,
      "meaning": "Connection username (role name)."
    },
    {
      "name": "passwordSecretRef",
      "type": "string",
      "required": true,
      "meaning": "Reference to secret store entry holding password."
    },
    {
      "name": "connectionString",
      "type": "string",
      "required": true,
      "meaning": "Full client connection URL (secret-bearing)."
    }
  ],
  "capabilities": [
    "pitr",
    "read-replicas",
    "high-availability",
    "backups",
    "ssl-required",
    "ipv6",
    "extensions"
  ]
}
